
@{
    ViewData["Title"] = "NurseList";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

﻿<main id="app-content">

    <style>
        /* ── Stat Grid ── */
        .hn-stat-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 14px;
            margin-bottom: 24px;
        }
        @@media(max - width:900px) {
            .hn-stat-grid

        {
            grid-template-columns: repeat(2,1fr)
        }

        }
        @@media(max - width:480px) {
            .hn-stat-grid

        {
            grid-template-columns: 1fr 1fr;
            gap: 10px
        }

        }

        .hn-stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            box-shadow: var(--shadow);
            transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
        }

            .hn-stat-card:hover {
                box-shadow: 0 4px 20px rgba(59,130,246,.13);
                transform: translateY(-2px);
            }

        .hn-si {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 19px;
        }

        .hn-si-blue {
            background: var(--primary-bg);
            color: var(--primary);
        }

        .hn-si-green {
            background: var(--success-bg);
            color: var(--success);
        }

        .hn-si-orange {
            background: var(--warning-bg);
            color: var(--warning);
        }

        .hn-si-purple {
            background: #F3F0FF;
            color: #7C3AED;
        }

        .hn-stat-val {
            font-size: 22px;
            font-weight: 700;
            color: var(--text);
            line-height: 1.1;
        }

        .hn-stat-lbl {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 500;
            margin-top: 2px;
        }

        .hn-stat-sub {
            font-size: 11px;
            font-weight: 600;
            margin-top: 4px;
        }

            .hn-stat-sub.up {
                color: var(--success);
            }

            .hn-stat-sub.down {
                color: var(--danger);
            }

        /* ── Toolbar ── */
        .hn-toolbar {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .hn-search-wrap {
            position: relative;
            flex: 1;
            min-width: 160px;
            max-width: 280px;
        }

            .hn-search-wrap i {
                position: absolute;
                left: 11px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 13px;
                pointer-events: none;
            }

            .hn-search-wrap input {
                width: 100%;
                border: 1px solid var(--border);
                border-radius: 20px;
                padding: 8px 14px 8px 32px;
                font-size: 13px;
                font-family: inherit;
                background: var(--surface);
                color: var(--text);
                outline: none;
                transition: border-color var(--dur), box-shadow var(--dur);
            }

                .hn-search-wrap input:focus {
                    border-color: var(--primary);
                    box-shadow: 0 0 0 3px rgba(59,130,246,.1);
                }

                .hn-search-wrap input::placeholder {
                    color: var(--text-muted);
                }

        .hn-tabs {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }

        .hn-tab {
            border: 1px solid var(--border);
            background: var(--surface);
            border-radius: 20px;
            padding: 7px 15px;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            cursor: pointer;
            transition: all var(--dur) var(--ease);
            white-space: nowrap;
        }

            .hn-tab:hover {
                background: var(--primary-bg);
                color: var(--primary);
                border-color: #C7D9F8;
            }

            .hn-tab.active {
                background: var(--primary);
                color: #fff;
                border-color: var(--primary);
            }

        .hn-sort-select {
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 8px 12px;
            font-size: 12px;
            font-family: inherit;
            background: var(--surface);
            color: var(--text);
            outline: none;
            cursor: pointer;
        }

        .hn-view-toggle {
            display: flex;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            overflow: hidden;
            flex-shrink: 0;
        }

        .hn-vbtn {
            width: 34px;
            height: 34px;
            border: none;
            background: var(--surface);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: var(--text-muted);
            cursor: pointer;
            transition: all var(--dur);
        }

            .hn-vbtn.active {
                background: var(--primary-bg);
                color: var(--primary);
            }

        /* ── Grid ── */
        #hn-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(290px,1fr));
            gap: 18px;
        }

            #hn-grid.list-mode {
                grid-template-columns: 1fr;
            }

        /* Entry animation */
        .hn-card {
            animation: hnFadeUp .3s var(--ease) both;
        }

            .hn-card:nth-child(1) {
                animation-delay: .04s
            }

            .hn-card:nth-child(2) {
                animation-delay: .08s
            }

            .hn-card:nth-child(3) {
                animation-delay: .12s
            }

            .hn-card:nth-child(4) {
                animation-delay: .16s
            }

            .hn-card:nth-child(5) {
                animation-delay: .20s
            }

            .hn-card:nth-child(6) {
                animation-delay: .24s
            }

            .hn-card:nth-child(7) {
                animation-delay: .28s
            }

            .hn-card:nth-child(8) {
                animation-delay: .32s
            }
        @@keyframes hnFadeUp {
            from

        {
            opacity: 0;
            transform: translateY(16px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }

        }

        /* Card */
        .hn-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease), border-color var(--dur);
        }

            .hn-card:hover {
                box-shadow: 0 4px 24px rgba(59,130,246,.13);
                transform: translateY(-3px);
                border-color: #C7D9F8;
            }

        /* Card header band */
        .hn-card-band {
            height: 6px;
            width: 100%;
            flex-shrink: 0;
        }

        /* Card body */
        .hn-card-body {
            padding: 20px 20px 14px;
            flex: 1;
        }

        /* Top section: avatar + info */
        .hn-card-top {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            margin-bottom: 14px;
        }

        .hn-avatar-wrap {
            position: relative;
            flex-shrink: 0;
        }

        .hn-avatar {
            width: 58px;
            height: 58px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 700;
            color: #fff;
            border: 3px solid var(--surface);
            box-shadow: 0 3px 10px rgba(0,0,0,.12);
        }

        .hn-online-dot {
            position: absolute;
            bottom: 2px;
            right: 2px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            border: 2px solid var(--surface);
        }

            .hn-online-dot.on {
                background: var(--success);
            }

            .hn-online-dot.off {
                background: var(--warning);
            }

            .hn-online-dot.leave {
                background: #94A3B8;
            }

        .hn-info {
            flex: 1;
            min-width: 0;
        }

        .hn-name {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 3px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .hn-role {
            font-size: 12px;
            color: var(--text-muted);
            margin-bottom: 6px;
        }

        .hn-tags {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }

        .hn-tag {
            font-size: 10px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 20px;
            white-space: nowrap;
        }

            .hn-tag.dept {
                background: var(--primary-bg);
                color: var(--primary-dk);
            }

            .hn-tag.shift-day {
                background: var(--success-bg);
                color: #065F46;
            }

            .hn-tag.shift-night {
                background: #1E1B4B11;
                color: #4338CA;
            }

            .hn-tag.shift-eve {
                background: var(--warning-bg);
                color: #92400E;
            }

        /* Status badge */
        .hn-status {
            margin-left: auto;
            flex-shrink: 0;
            font-size: 10px;
            font-weight: 700;
            padding: 3px 9px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 4px;
        }

            .hn-status.on {
                background: var(--success-bg);
                color: #065F46;
            }

            .hn-status.off {
                background: var(--warning-bg);
                color: #92400E;
            }

            .hn-status.leave {
                background: #F1F5F9;
                color: #475569;
            }

        .hn-status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }

        .hn-status.on .hn-status-dot {
            background: var(--success);
        }

        .hn-status.off .hn-status-dot {
            background: var(--warning);
        }

        .hn-status.leave .hn-status-dot {
            background: #94A3B8;
        }

        /* Stat cells */
        .hn-stats {
            display: flex;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            overflow: hidden;
            margin-bottom: 14px;
        }

        .hn-sc {
            flex: 1;
            text-align: center;
            padding: 9px 4px;
            border-right: 1px solid var(--border);
            background: var(--bg);
            transition: background var(--dur);
        }

            .hn-sc:last-child {
                border-right: none;
            }

            .hn-sc:hover {
                background: var(--primary-bg);
            }

        .hn-sc-val {
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
            line-height: 1.1;
        }

        .hn-sc-lbl {
            font-size: 10px;
            color: var(--text-muted);
            font-weight: 500;
            margin-top: 2px;
        }

        /* Skills */
        .hn-skills {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            margin-bottom: 14px;
        }

        .hn-skill {
            font-size: 10.5px;
            font-weight: 600;
            padding: 3px 9px;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: var(--bg);
            color: var(--text-muted);
            transition: all var(--dur);
        }

            .hn-skill:hover {
                background: var(--primary-bg);
                color: var(--primary);
                border-color: #C7D9F8;
            }

        /* Progress bar */
        .hn-prog-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 4px;
        }

        .hn-prog-lbl {
            font-size: 11px;
            color: var(--text-muted);
            white-space: nowrap;
            min-width: 80px;
        }

        .hn-prog-track {
            flex: 1;
            height: 5px;
            background: var(--border);
            border-radius: 10px;
            overflow: hidden;
        }

        .hn-prog-fill {
            height: 100%;
            border-radius: 10px;
            transition: width .6s var(--ease);
        }

        .hn-prog-pct {
            font-size: 11px;
            font-weight: 700;
            min-width: 28px;
            text-align: right;
        }

        /* Card footer */
        .hn-card-footer {
            padding: 11px 14px;
            border-top: 1px solid var(--border);
            background: #FAFBFE;
            display: flex;
            gap: 6px;
        }

        .hn-btn {
            flex: 1;
            border: 1px solid var(--border);
            background: var(--surface);
            border-radius: var(--radius-sm);
            padding: 7px 8px;
            font-size: 12px;
            font-weight: 600;
            font-family: inherit;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
            cursor: pointer;
            transition: all var(--dur) var(--ease);
            color: var(--text-muted);
        }

            .hn-btn:hover {
                background: var(--bg);
                color: var(--text);
            }

            .hn-btn.primary {
                color: var(--primary);
                border-color: #C7D9F8;
                background: var(--primary-bg);
            }

                .hn-btn.primary:hover {
                    background: var(--primary);
                    color: #fff;
                    box-shadow: 0 3px 10px rgba(59,130,246,.25);
                }

            .hn-btn.danger:hover {
                background: var(--danger-bg);
                border-color: #FCA5A5;
                color: var(--danger);
            }

        /* ── LIST MODE ── */
        #hn-grid.list-mode .hn-card {
            flex-direction: row;
        }

        #hn-grid.list-mode .hn-card-band {
            width: 5px;
            height: auto;
        }

        #hn-grid.list-mode .hn-card-body {
            display: flex;
            align-items: center;
            gap: 18px;
            flex-wrap: wrap;
            padding: 13px 18px;
        }

        #hn-grid.list-mode .hn-card-top {
            margin-bottom: 0;
            flex-shrink: 0;
            align-items: center;
        }

        #hn-grid.list-mode .hn-avatar {
            width: 44px;
            height: 44px;
            font-size: 14px;
        }

        #hn-grid.list-mode .hn-info {
            min-width: 160px;
        }

        #hn-grid.list-mode .hn-tags {
            margin-top: 4px;
        }

        #hn-grid.list-mode .hn-stats {
            margin-bottom: 0;
            flex-shrink: 0;
            min-width: 196px;
        }

        #hn-grid.list-mode .hn-skills {
            display: none;
        }

        #hn-grid.list-mode .hn-prog-row {
            display: none;
        }

        #hn-grid.list-mode .hn-card-footer {
            flex-direction: column;
            border-top: none;
            border-left: 1px solid var(--border);
            padding: 11px 11px;
            min-width: 116px;
            gap: 5px;
            justify-content: center;
        }

        #hn-grid.list-mode .hn-btn {
            flex: unset;
            width: 100%;
        }

        /* ── Empty ── */
        .hn-empty {
            grid-column: 1/-1;
            text-align: center;
            padding: 72px 24px;
            color: var(--text-muted);
        }

            .hn-empty i {
                font-size: 48px;
                opacity: .15;
                display: block;
                margin-bottom: 14px;
            }

        .hn-empty-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 6px;
        }

        /* ── Nöbet Takvimi Panel ── */
        .hn-schedule-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            margin-top: 24px;
            overflow: hidden;
        }

        .hn-schedule-header {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .hn-schedule-title {
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
        }

        .hn-schedule-grid-wrap {
            overflow-x: auto;
            padding: 0 0 4px;
        }

        .hn-schedule-grid {
            display: grid;
            grid-template-columns: 160px repeat(7,1fr);
            min-width: 640px;
        }

        .hn-sg-head {
            padding: 10px 12px;
            background: var(--bg);
            border-right: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: var(--text-muted);
        }

            .hn-sg-head:last-child {
                border-right: none;
            }

        .hn-sg-name {
            padding: 10px 14px;
            border-right: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--surface);
        }

            .hn-sg-name:last-of-type {
                border-bottom: none;
            }

        .hn-sg-av {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            font-weight: 700;
            color: #fff;
        }

        .hn-sg-nm {
            font-size: 12px;
            font-weight: 600;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .hn-sg-cell {
            padding: 8px 6px;
            border-right: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--surface);
            transition: background var(--dur);
        }

            .hn-sg-cell:last-child {
                border-right: none;
            }

            .hn-sg-cell:hover {
                background: var(--bg);
            }

        .hn-shift-chip {
            font-size: 10px;
            font-weight: 700;
            padding: 3px 8px;
            border-radius: 6px;
            white-space: nowrap;
            cursor: default;
        }

            .hn-shift-chip.day {
                background: var(--success-bg);
                color: #065F46;
            }

            .hn-shift-chip.night {
                background: #EEF2FF;
                color: #4338CA;
            }

            .hn-shift-chip.eve {
                background: var(--warning-bg);
                color: #92400E;
            }

            .hn-shift-chip.off {
                background: #F1F5F9;
                color: #94A3B8;
            }

        /* ── Modal ── */
        .hn-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,.45);
            z-index: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
            opacity: 0;
            pointer-events: none;
            transition: opacity .2s ease;
        }

            .hn-overlay.show {
                opacity: 1;
                pointer-events: all;
            }

        .hn-modal-box {
            background: var(--surface);
            border-radius: var(--radius);
            box-shadow: 0 20px 60px rgba(0,0,0,.18);
            width: 100%;
            max-width: 520px;
            transform: scale(.93) translateY(16px);
            transition: transform .26s cubic-bezier(.34,1.56,.64,1);
        }

        .hn-overlay.show .hn-modal-box {
            transform: scale(1) translateY(0);
        }

        .hn-modal-header {
            padding: 18px 22px 14px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
        }

        .hn-modal-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
        }

        .hn-modal-subtitle {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 3px;
        }

        .hn-modal-close {
            width: 30px;
            height: 30px;
            border: 1px solid var(--border);
            background: transparent;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: var(--text-muted);
            cursor: pointer;
            flex-shrink: 0;
            transition: background var(--dur);
        }

            .hn-modal-close:hover {
                background: var(--bg);
            }

        .hn-modal-body {
            padding: 20px 22px;
        }

        .hn-modal-footer {
            padding: 14px 22px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 8px;
        }

        .hn-form-label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .05em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 5px;
        }

        .hn-form-control {
            width: 100%;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 9px 12px;
            font-size: 13px;
            font-family: inherit;
            color: var(--text);
            background: var(--bg);
            outline: none;
            transition: border-color var(--dur), box-shadow var(--dur);
        }

            .hn-form-control:focus {
                border-color: var(--primary);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(59,130,246,.1);
            }

        .hn-form-group {
            margin-bottom: 14px;
        }

        /* Profile modal header */
        .hn-prof-head {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 20px 22px;
            border-bottom: 1px solid var(--border);
            background: linear-gradient(135deg,#EFF6FF,#F8FAFC);
        }

        .hn-prof-av {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 700;
            color: #fff;
            border: 3px solid #fff;
            box-shadow: 0 4px 14px rgba(0,0,0,.12);
        }

        .hn-prof-name {
            font-size: 17px;
            font-weight: 700;
            color: var(--text);
        }

        .hn-prof-title {
            font-size: 13px;
            color: var(--text-muted);
            margin-top: 3px;
        }

        .hn-detail-row {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 9px 0;
            border-bottom: 1px solid var(--border);
        }

            .hn-detail-row:last-child {
                border-bottom: none;
            }

        .hn-detail-label {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-muted);
