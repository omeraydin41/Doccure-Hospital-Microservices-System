            </div>
            <div class="hn-modal-body" style="text-align:center;padding:36px 24px">
                <i class="bi bi-heart-pulse" style="font-size:44px;color:var(--primary);opacity:.2;display:block;margin-bottom:14px"></i>
                <div style="font-size:15px;font-weight:700;margin-bottom:6px">Sayfa henüz bağlanmadı</div>
                <p style="font-size:13px;color:var(--text-muted);line-height:1.7">Yeni hemşire ekleme sayfanızı oluşturup<br>bu modal içeriğini kendi formunuzla değiştirin.</p>
            </div>
            <div class="hn-modal-footer">
                <button class="hn-btn-outline" onclick="HN.close('hn-m-add')">Kapat</button>
                <button class="hn-btn-primary" onclick="HN.close('hn-m-add');Shell.toast('Ekleme sayfasına yönlendiriliyor...','info','bi-arrow-right-circle')">
                    <i class="bi bi-box-arrow-up-right"></i> Sayfaya Git
                </button>
            </div>
        </div>
    </div>

    <!-- Nöbet Planlama (placeholder) -->
    <div class="hn-overlay" id="hn-m-schedule" onclick="if(event.target===this)HN.close('hn-m-schedule')">
        <div class="hn-modal-box" style="max-width:440px">
            <div class="hn-modal-header">
                <div class="hn-modal-title"><i class="bi bi-calendar-week me-2" style="color:var(--primary)"></i>Nöbet Planla</div>
                <button class="hn-modal-close" onclick="HN.close('hn-m-schedule')"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="hn-modal-body" style="text-align:center;padding:36px 24px">
                <i class="bi bi-calendar2-week" style="font-size:44px;color:var(--primary);opacity:.2;display:block;margin-bottom:14px"></i>
                <div style="font-size:15px;font-weight:700;margin-bottom:6px">Nöbet planlama modülü</div>
                <p style="font-size:13px;color:var(--text-muted);line-height:1.7">Detaylı nöbet planlama sayfanızı oluşturup<br>buraya bağlayabilirsiniz.</p>
            </div>
            <div class="hn-modal-footer">
                <button class="hn-btn-outline" onclick="HN.close('hn-m-schedule')">Kapat</button>
                <button class="hn-btn-primary" onclick="HN.close('hn-m-schedule');Shell.toast('Nöbet planlama sayfasına yönlendiriliyor...','info','bi-calendar-week')">
                    <i class="bi bi-box-arrow-up-right"></i> Sayfaya Git
                </button>
            </div>
        </div>
    </div>


    <!-- ── PAGE JS ── -->
    <script>
        const HN = (() => {
          let _cat     = 'all';
          let _delName = '';
          let _delCard = null;

          /* ─ View ─ */
          function setView(v) {
            document.getElementById('hn-grid').classList.toggle('list-mode', v === 'list');
            document.getElementById('hn-vg').classList.toggle('active', v === 'grid');
            document.getElementById('hn-vl').classList.toggle('active', v === 'list');
          }

          /* ─ Tab ─ */
          function setTab(el) {
            document.querySelectorAll('.hn-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            _cat = el.dataset.cat;
            filter();
          }

          /* ─ Filter ─ */
          function filter() {
            const q = (document.getElementById('hn-search').value || '').toLowerCase().trim();
            let n = 0;
            document.querySelectorAll('#hn-grid .hn-card').forEach(c => {
              const catOk = _cat === 'all'
                || (_cat === 'musait' && c.dataset.status === 'on')
                || c.dataset.cat === _cat;
              const nameOk = c.dataset.name.includes(q);
              const show = catOk && nameOk;
              c.style.display = show ? '' : 'none';
              if (show) n++;
            });
            const cnt = document.getElementById('hn-count');
            if (cnt) cnt.textContent = n;
            let empty = document.getElementById('hn-empty');
            if (n === 0 && !empty) {
              empty = document.createElement('div');
              empty.id = 'hn-empty'; empty.className = 'hn-empty';
              empty.innerHTML = '<i class="bi bi-person-x"></i><div class="hn-empty-title">Hemşire bulunamadı</div><div style="font-size:13px">Farklı arama terimi veya filtre deneyin.</div>';
              document.getElementById('hn-grid').appendChild(empty);
            } else if (n > 0 && empty) { empty.remove(); }
          }

          /* ─ Sort ─ */
          function sort(by) {
            Shell.toast(`Hemşireler ${by === 'name' ? 'ada' : by === 'exp' ? 'deneyime' : 'performansa'} göre sıralandı.`, 'info', 'bi-sort-down');
          }

          /* ─ Modal helpers ─ */
          function open(id)  { document.getElementById(id).classList.add('show'); document.body.style.overflow = 'hidden'; }
          function close(id) { document.getElementById(id).classList.remove('show'); document.body.style.overflow = ''; }

          /* ─ Add / Schedule ─ */
          function openAdd()      { open('hn-m-add'); }
          function openSchedule() { open('hn-m-schedule'); }

          /* ─ Profile ─ */
          function openProfile(name, role, dept, exp, hours, email, phone, perf, patients) {
            const initials = name.split(' ').map(w => w[0]).join('').slice(0,2);
            document.getElementById('hn-pr-av').textContent    = initials;
            document.getElementById('hn-pr-name').textContent  = name;
            document.getElementById('hn-pr-title').textContent = role;
            document.getElementById('hn-pr-dept').textContent  = dept;
            document.getElementById('hn-pr-exp').textContent   = exp;
            document.getElementById('hn-pr-perf').textContent  = '%' + perf;
            document.getElementById('hn-pr-patients').textContent = patients;
            document.getElementById('hn-pr-hours').textContent = hours;
            document.getElementById('hn-pr-email').textContent = email;
            document.getElementById('hn-pr-phone').textContent = phone;
            open('hn-m-profile');
          }

          /* ─ Edit ─ */
          function openEdit(name, dept, exp, cat) {
            document.getElementById('hn-e-name').value = name;
            document.getElementById('hn-e-dept').value = dept;
            document.getElementById('hn-e-exp').value  = exp;
            document.getElementById('hn-e-cat').value  = cat;
            document.getElementById('hn-edit-sub').textContent = name + ' · ' + dept;
            open('hn-m-edit');
          }
          function saveEdit() {
            const n = document.getElementById('hn-e-name').value.trim();
            if (!n) { Shell.toast('Ad Soyad boş olamaz!', 'danger', 'bi-exclamation-circle'); return; }
            close('hn-m-edit');
            Shell.toast(`${n} bilgileri güncellendi.`, 'success', 'bi-check-circle');
          }

          /* ─ Delete ─ */
          function confirmDelete(name, btn) {
            _delName = name;
            _delCard = btn.closest('.hn-card');
            document.getElementById('hn-del-name').textContent = name;
            open('hn-m-delete');
          }
          function execDelete() {
            close('hn-m-delete');
            if (_delCard) {
              _delCard.style.transition = 'opacity .3s ease, transform .3s ease';
              _delCard.style.opacity    = '0';
              _delCard.style.transform  = 'scale(.94)';
              setTimeout(() => { _delCard?.remove(); _delCard = null; filter(); }, 320);
            }
            Shell.toast(`${_delName} sistemden silindi.`, 'danger', 'bi-trash3');
          }

          /* ─ Export ─ */
          function exportList() {
            Shell.toast('Hemşire listesi Excel olarak hazırlanıyor...', 'info', 'bi-file-earmark-spreadsheet');
          }

          /* ─ ESC ─ */
          document.addEventListener('keydown', e => {
            if (e.key === 'Escape')
              document.querySelectorAll('.hn-overlay.show').forEach(m => close(m.id));
          });

          /* ─ Init ─ */
          if (typeof Shell !== 'undefined' && Shell.setPage)
            Shell.setPage('Hemşireler', 'Admin Paneli / Klinik / Hemşireler');

          return { setView, setTab, filter, sort, openAdd, openSchedule, openProfile, openEdit, saveEdit, confirmDelete, execDelete, exportList, close };
        })();
    </script>

</main>
