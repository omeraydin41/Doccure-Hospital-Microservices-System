    <!-- ── PAGE JS ── -->
    <script>
        const DC = (() => {
          let _cat     = 'all';
          let _delName = '';
          let _delCard = null;

          /* ─ View ─ */
          function setView(v) {
            document.getElementById('dc-grid').classList.toggle('list-mode', v === 'list');
            document.getElementById('dc-vg').classList.toggle('active', v === 'grid');
            document.getElementById('dc-vl').classList.toggle('active', v === 'list');
          }

          /* ─ Tab ─ */
          function setTab(el) {
            document.querySelectorAll('.dc-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            _cat = el.dataset.cat;
            filter();
          }

          /* ─ Filter ─ */
          function filter() {
            const q = (document.getElementById('dc-search').value || '').toLowerCase().trim();
            let n = 0;
            document.querySelectorAll('#dc-grid .dc-card').forEach(c => {
              const catOk = _cat === 'all'
                || (_cat === 'musait' && c.dataset.status === 'on')
                || c.dataset.cat === _cat;
              const nameOk = c.dataset.name.includes(q);
              const show = catOk && nameOk;
              c.style.display = show ? '' : 'none';
              if (show) n++;
            });
            const cnt = document.getElementById('dc-count');
            if (cnt) cnt.textContent = n;
            let empty = document.getElementById('dc-empty');
            if (n === 0 && !empty) {
              empty = document.createElement('div');
              empty.id = 'dc-empty'; empty.className = 'dc-empty';
              empty.innerHTML = '<i class="bi bi-person-x"></i><div class="dc-empty-title">Doktor bulunamadı</div><div style="font-size:13px">Farklı bir arama terimi veya filtre deneyin.</div>';
              document.getElementById('dc-grid').appendChild(empty);
            } else if (n > 0 && empty) { empty.remove(); }
          }

          /* ─ Sort ─ */
          function sort(by) {
            Shell.toast(`Doktorlar ${by === 'name' ? 'ada' : by === 'rating' ? 'puana' : by === 'exp' ? 'deneyime' : 'randevuya'} göre sıralandı.`, 'info', 'bi-sort-down');
          }

          /* ─ Book ─ */
          function book(doc, time) {
            Shell.toast(`${doc} · ${time} için randevu oluşturuldu!`, 'success', 'bi-calendar-check');
          }

          /* ─ Modals ─ */
          function open(id) {
            document.getElementById(id).classList.add('show');
            document.body.style.overflow = 'hidden';
          }
          function close(id) {
            document.getElementById(id).classList.remove('show');
            document.body.style.overflow = '';
          }

          /* ─ Add ─ */
          function openAdd() { open('dc-m-add'); }

          /* ─ Profile ─ */
          function openProfile(name, spec, exp, edu, hours, email, phone, patients, appt, rating) {
            const initials = name.replace('Dr. ','').split(' ').map(w=>w[0]).join('').slice(0,2);
            const av = document.getElementById('dc-pr-av');
            av.textContent = initials;
            document.getElementById('dc-pr-name').textContent    = name;
            document.getElementById('dc-pr-title').textContent   = spec;
            document.getElementById('dc-pr-dept').textContent    = spec.replace(' Uzmanı','');
            document.getElementById('dc-pr-spec').textContent    = spec;
            document.getElementById('dc-pr-exp').textContent     = exp + ' deneyim';
            document.getElementById('dc-pr-edu').textContent     = edu;
            document.getElementById('dc-pr-hours').textContent   = hours;
            document.getElementById('dc-pr-email').textContent   = email;
            document.getElementById('dc-pr-phone').textContent   = phone;
            document.getElementById('dc-pr-patients').textContent= patients;
            document.getElementById('dc-pr-appt').textContent    = appt;
            document.getElementById('dc-pr-rating').textContent  = '⭐ ' + rating;
            open('dc-m-profile');
          }

          /* ─ Edit ─ */
          function openEdit(name, spec, exp, cat, edu) {
            document.getElementById('dc-edit-name').value     = name;
            document.getElementById('dc-edit-spec').value     = spec;
            document.getElementById('dc-edit-exp').value      = exp;
            document.getElementById('dc-edit-cat').value      = cat;
            document.getElementById('dc-edit-edu').value      = edu;
            document.getElementById('dc-edit-subtitle').textContent = name + ' · ' + spec;
            open('dc-m-edit');
          }
          function saveEdit() {
            const n = document.getElementById('dc-edit-name').value.trim();
            if (!n) { Shell.toast('Ad Soyad boş olamaz!', 'danger', 'bi-exclamation-circle'); return; }
            close('dc-m-edit');
            Shell.toast(`${n} bilgileri güncellendi.`, 'success', 'bi-check-circle');
          }

          /* ─ Delete ─ */
          function confirmDelete(name, btn) {
            _delName = name;
            _delCard = btn.closest('.dc-card');
            document.getElementById('dc-del-name').textContent = name;
            open('dc-m-delete');
          }
          function execDelete() {
            close('dc-m-delete');
            if (_delCard) {
              _delCard.style.transition = 'opacity .3s ease, transform .3s ease';
              _delCard.style.opacity    = '0';
              _delCard.style.transform  = 'scale(.94)';
              setTimeout(() => { _delCard?.remove(); _delCard = null; filter(); }, 320);
            }
            Shell.toast(`${_delName} sistemden silindi.`, 'danger', 'bi-trash3');
          }

          /* ─ Export ─ */
          function exportList() {
            Shell.toast('Doktor listesi Excel olarak hazırlanıyor...', 'info', 'bi-file-earmark-spreadsheet');
          }

          /* ─ ESC ─ */
          document.addEventListener('keydown', e => {
            if (e.key === 'Escape')
              document.querySelectorAll('.dc-overlay.show').forEach(m => close(m.id));
          });

          /* ─ Topbar ─ */
          if (typeof Shell !== 'undefined' && Shell.setPage)
            Shell.setPage('Doktorlar', 'Admin Paneli / Klinik / Doktorlar');

          return { setView, setTab, filter, sort, book, openAdd, openProfile, openEdit, saveEdit, confirmDelete, execDelete, exportList, close };
        })();
    </script>

</main>
