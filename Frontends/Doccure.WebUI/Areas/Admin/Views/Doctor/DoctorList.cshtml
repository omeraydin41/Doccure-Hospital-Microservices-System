
@{
    ViewData["Title"] = "DoctorList";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

﻿<main id="app-content">

    <style>
        /* ── Stat Grid ── */
        .dc-stat-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 14px;
            margin-bottom: 24px;
        }
        @@media(max - width:900px) {
            .dc-stat-grid

        {
            grid-template-columns: repeat(2,1fr)
        }

        }
        @@media(max - width:480px) {
            .dc-stat-grid

        {
            grid-template-columns: 1fr 1fr;
            gap: 10px
        }

        }

        .dc-stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            box-shadow: var(--shadow);
            transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
        }

            .dc-stat-card:hover {
                box-shadow: 0 4px 20px rgba(59,130,246,.13);
                transform: translateY(-2px);
            }

        .dc-si {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 19px;
        }

        .dc-si-blue {
            background: var(--primary-bg);
            color: var(--primary);
        }

        .dc-si-green {
            background: var(--success-bg);
            color: var(--success);
        }

        .dc-si-orange {
            background: var(--warning-bg);
            color: var(--warning);
        }

        .dc-si-red {
            background: var(--danger-bg);
            color: var(--danger);
        }

        .dc-stat-val {
            font-size: 22px;
            font-weight: 700;
            color: var(--text);
            line-height: 1.1;
        }

        .dc-stat-lbl {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 500;
            margin-top: 2px;
        }

        .dc-stat-sub {
            font-size: 11px;
            font-weight: 600;
            margin-top: 4px;
        }

            .dc-stat-sub.up {
                color: var(--success);
            }

            .dc-stat-sub.down {
                color: var(--danger);
            }

        /* ── Toolbar ── */
        .dc-toolbar {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .dc-local-search {
            position: relative;
            flex: 1;
            min-width: 160px;
            max-width: 280px;
        }

            .dc-local-search i {
                position: absolute;
                left: 11px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 13px;
                pointer-events: none;
            }

            .dc-local-search input {
                width: 100%;
                border: 1px solid var(--border);
                border-radius: 20px;
                padding: 8px 14px 8px 32px;
                font-size: 13px;
                font-family: inherit;
                background: var(--surface);
                color: var(--text);
                outline: none;
                transition: border-color var(--dur), box-shadow var(--dur);
            }

                .dc-local-search input:focus {
                    border-color: var(--primary);
                    box-shadow: 0 0 0 3px rgba(59,130,246,.1);
                }

                .dc-local-search input::placeholder {
                    color: var(--text-muted);
                }

        .dc-tabs {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }

        .dc-tab {
            border: 1px solid var(--border);
            background: var(--surface);
            border-radius: 20px;
            padding: 7px 15px;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            cursor: pointer;
            transition: all var(--dur) var(--ease);
            white-space: nowrap;
        }

            .dc-tab:hover {
                background: var(--primary-bg);
                color: var(--primary);
                border-color: #C7D9F8;
            }

            .dc-tab.active {
                background: var(--primary);
                color: #fff;
                border-color: var(--primary);
            }

        .dc-sort-select {
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 7px 12px;
            font-size: 12px;
            font-family: inherit;
            background: var(--surface);
            color: var(--text);
            outline: none;
            cursor: pointer;
        }

        .dc-view-toggle {
            display: flex;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            overflow: hidden;
            flex-shrink: 0;
        }

        .dc-vbtn {
            width: 34px;
            height: 34px;
            border: none;
            background: var(--surface);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: var(--text-muted);
            cursor: pointer;
            transition: all var(--dur);
        }

            .dc-vbtn.active {
                background: var(--primary-bg);
                color: var(--primary);
            }

        /* ── Card Grid ── */
        #dc-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px,1fr));
            gap: 18px;
        }

            #dc-grid.list-mode {
                grid-template-columns: 1fr;
            }

        /* Entry animation */
        .dc-card {
            animation: dcFadeUp .3s var(--ease) both;
        }

            .dc-card:nth-child(1) {
                animation-delay: .04s
            }

            .dc-card:nth-child(2) {
                animation-delay: .08s
            }

            .dc-card:nth-child(3) {
                animation-delay: .12s
            }

            .dc-card:nth-child(4) {
                animation-delay: .16s
            }

            .dc-card:nth-child(5) {
                animation-delay: .20s
            }

            .dc-card:nth-child(6) {
                animation-delay: .24s
            }

            .dc-card:nth-child(7) {
                animation-delay: .28s
            }

            .dc-card:nth-child(8) {
                animation-delay: .32s
            }
        @@keyframes dcFadeUp {
            from

        {
            opacity: 0;
            transform: translateY(16px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }

        }

        /* Card */
        .dc-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease), border-color var(--dur);
            position: relative;
        }

            .dc-card:hover {
                box-shadow: 0 4px 24px rgba(59,130,246,.13);
                transform: translateY(-3px);
                border-color: #C7D9F8;
            }

        .dc-card-top {
            padding: 22px 20px 16px;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 10px;
            position: relative;
        }

        .dc-card-top-bg {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 70px;
            opacity: .07;
            border-radius: var(--radius) var(--radius) 0 0;
        }

        /* Status badge top-right */
        .dc-status-badge {
            position: absolute;
            top: 14px;
            right: 14px;
            font-size: 10px;
            font-weight: 700;
            padding: 3px 9px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 4px;
        }

            .dc-status-badge::before {
                content: '';
                width: 6px;
                height: 6px;
                border-radius: 50%;
                flex-shrink: 0;
            }

            .dc-status-badge.on {
                background: var(--success-bg);
                color: #065F46;
            }

                .dc-status-badge.on::before {
                    background: var(--success);
                }

            .dc-status-badge.off {
                background: var(--warning-bg);
                color: #92400E;
            }

                .dc-status-badge.off::before {
                    background: var(--warning);
                }

            .dc-status-badge.leave {
                background: #F1F5F9;
                color: var(--text-muted);
            }

                .dc-status-badge.leave::before {
                    background: #94A3B8;
                }

        /* Avatar */
        .dc-avatar {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: 700;
            color: #fff;
            border: 3px solid var(--surface);
            box-shadow: 0 4px 14px rgba(0,0,0,.12);
            flex-shrink: 0;
            position: relative;
            z-index: 1;
        }

        .dc-avatar-ring {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 4px;
            position: relative;
            z-index: 1;
        }

        .dc-doc-name {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            line-height: 1.3;
        }

        .dc-doc-spec {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
        }

        .dc-doc-dept {
            font-size: 11px;
            font-weight: 600;
            padding: 3px 10px;
            border-radius: 20px;
            background: var(--primary-bg);
            color: var(--primary);
        }

        /* Stars */
        .dc-stars {
            display: flex;
            align-items: center;
            gap: 3px;
            font-size: 12px;
        }

            .dc-stars i {
                color: #FBBF24;
                font-size: 12px;
            }

            .dc-stars span {
                font-weight: 700;
                color: var(--text);
                margin-left: 3px;
            }

            .dc-stars small {
                color: var(--text-muted);
                font-size: 10px;
            }

        /* Stats row */
        .dc-card-stats {
            display: flex;
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }

        .dc-cs-cell {
            flex: 1;
            text-align: center;
            padding: 10px 4px;
            border-right: 1px solid var(--border);
            background: var(--bg);
            transition: background var(--dur);
        }

            .dc-cs-cell:last-child {
                border-right: none;
            }

            .dc-cs-cell:hover {
                background: var(--primary-bg);
            }

        .dc-cs-val {
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
            line-height: 1.1;
        }

        .dc-cs-lbl {
            font-size: 10px;
            color: var(--text-muted);
            font-weight: 500;
            margin-top: 2px;
        }

        /* Availability slots */
        .dc-slots {
            padding: 12px 18px 14px;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .dc-slots-title {
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        .dc-slot-row {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }

        .dc-slot {
            font-size: 11px;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: var(--bg);
            color: var(--text-muted);
        }

            .dc-slot.free {
                background: var(--success-bg);
                color: #065F46;
                border-color: #A7F3D0;
                cursor: pointer;
                transition: all var(--dur);
            }

                .dc-slot.free:hover {
                    background: var(--success);
                    color: #fff;
                    border-color: var(--success);
                }

            .dc-slot.busy {
                background: var(--danger-bg);
                color: #991B1B;
                border-color: #FCA5A5;
            }

        /* Footer */
        .dc-card-footer {
            padding: 11px 14px;
            border-top: 1px solid var(--border);
            background: #FAFBFE;
            display: flex;
            gap: 6px;
            margin-top: auto;
        }

        .dc-btn {
            flex: 1;
            border: 1px solid var(--border);
            background: var(--surface);
            border-radius: var(--radius-sm);
            padding: 7px 8px;
            font-size: 12px;
            font-weight: 600;
            font-family: inherit;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
            cursor: pointer;
            transition: all var(--dur) var(--ease);
            color: var(--text-muted);
        }

            .dc-btn:hover {
                background: var(--bg);
                color: var(--text);
            }

            .dc-btn.primary {
                color: var(--primary);
                border-color: #C7D9F8;
                background: var(--primary-bg);
            }

                .dc-btn.primary:hover {
                    background: var(--primary);
                    color: #fff;
                    box-shadow: 0 3px 10px rgba(59,130,246,.25);
                }

            .dc-btn.success {
                color: var(--success);
                border-color: #A7F3D0;
                background: var(--success-bg);
            }

                .dc-btn.success:hover {
                    background: var(--success);
                    color: #fff;
                    box-shadow: 0 3px 10px rgba(16,185,129,.25);
                }

            .dc-btn.danger:hover {
                background: var(--danger-bg);
                border-color: #FCA5A5;
                color: var(--danger);
            }

        /* ── LIST MODE ── */
        #dc-grid.list-mode .dc-card {
            flex-direction: row;
            align-items: stretch;
        }

        #dc-grid.list-mode .dc-card-top {
            flex-direction: row;
            text-align: left;
            align-items: center;
            padding: 14px 20px;
            gap: 14px;
            min-width: 260px;
            flex-shrink: 0;
            border-right: 1px solid var(--border);
        }

        #dc-grid.list-mode .dc-card-top-bg {
            display: none;
        }

        #dc-grid.list-mode .dc-status-badge {
            position: static;
        }

        #dc-grid.list-mode .dc-avatar-ring {
            width: 52px;
            height: 52px;
            padding: 3px;
        }

        #dc-grid.list-mode .dc-avatar {
            width: 46px;
            height: 46px;
            font-size: 16px;
        }

        #dc-grid.list-mode .dc-stars small {
            display: none;
        }

        #dc-grid.list-mode .dc-card-stats {
            flex: 1;
            border-top: none;
            border-bottom: none;
            border-right: 1px solid var(--border);
            flex-direction: column;
        }

        #dc-grid.list-mode .dc-cs-cell {
            border-right: none;
            border-bottom: 1px solid var(--border);
            padding: 8px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            text-align: left;
        }

            #dc-grid.list-mode .dc-cs-cell:last-child {
                border-bottom: none;
            }

        #dc-grid.list-mode .dc-cs-lbl {
            font-size: 11px;
        }

        #dc-grid.list-mode .dc-slots {
            display: none;
        }

        #dc-grid.list-mode .dc-card-footer {
            flex-direction: column;
            border-top: none;
            border-left: none;
            padding: 12px;
            min-width: 120px;
            gap: 5px;
            justify-content: center;
        }

        #dc-grid.list-mode .dc-btn {
            flex: unset;
            width: 100%;
        }

        /* ── Empty ── */
        .dc-empty {
            grid-column: 1/-1;
            text-align: center;
            padding: 72px 24px;
            color: var(--text-muted);
        }

            .dc-empty i {
                font-size: 48px;
                opacity: .15;
                display: block;
                margin-bottom: 14px;
            }

        .dc-empty-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 6px;
        }

        /* ── Modals ── */
        .dc-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,.45);
            z-index: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
            opacity: 0;
            pointer-events: none;
            transition: opacity .2s ease;
        }

            .dc-overlay.show {
                opacity: 1;
                pointer-events: all;
            }

        .dc-modal-box {
            background: var(--surface);
            border-radius: var(--radius);
            box-shadow: 0 20px 60px rgba(0,0,0,.18);
            width: 100%;
            max-width: 560px;
            transform: scale(.93) translateY(16px);
            transition: transform .26s cubic-bezier(.34,1.56,.64,1);
        }

        .dc-overlay.show .dc-modal-box {
            transform: scale(1) translateY(0);
        }

        .dc-modal-header {
            padding: 18px 22px 14px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
        }

        .dc-modal-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
        }

        .dc-modal-subtitle {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 3px;
        }

        .dc-modal-close {
            width: 30px;
            height: 30px;
            border: 1px solid var(--border);
            background: transparent;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: var(--text-muted);
            cursor: pointer;
            flex-shrink: 0;
            transition: background var(--dur);
        }

            .dc-modal-close:hover {
                background: var(--bg);
            }

        .dc-modal-body {
            padding: 20px 22px;
        }

        .dc-modal-footer {
            padding: 14px 22px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 8px;
        }

        .dc-form-label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .05em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 5px;
        }

        .dc-form-control {
            width: 100%;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 9px 12px;
            font-size: 13px;
            font-family: inherit;
            color: var(--text);
            background: var(--bg);
            outline: none;
            transition: border-color var(--dur), box-shadow var(--dur);
        }

            .dc-form-control:focus {
                border-color: var(--primary);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(59,130,246,.1);
            }

        .dc-form-group {
            margin-bottom: 16px;
        }

        /* Profile modal */
        .dc-profile-header {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 20px 22px;
            border-bottom: 1px solid var(--border);
            background: linear-gradient(135deg, #EFF6FF 0%, #F8FAFC 100%);
        }

        .dc-profile-av {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            font-weight: 700;
            color: #fff;
            border: 3px solid #fff;
            box-shadow: 0 4px 14px rgba(0,0,0,.12);
        }

        .dc-profile-name {
            font-size: 17px;
            font-weight: 700;
            color: var(--text);
        }

        .dc-profile-title {
            font-size: 13px;
            color: var(--text-muted);
            margin-top: 3px;
        }

        .dc-profile-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

            .dc-profile-table td {
                padding: 9px 0;
                border-bottom: 1px solid var(--border);
                vertical-align: top;
            }

            .dc-profile-table tr:last-child td {
                border-bottom: none;
            }

            .dc-profile-table td:first-child {
                color: var(--text-muted);
                font-weight: 600;
                width: 140px;
                font-size: 11.5px;
            }

        /* Delete danger note */
        .dc-danger-note {
            background: var(--danger-bg);
            border: 1px solid #FCA5A5;
            border-radius: var(--radius-sm);
            padding: 11px 13px;
            font-size: 12px;
            color: #991B1B;
            margin-top: 12px;
            display: flex;
            gap: 8px;
            align-items: flex-start;
        }

            .dc-danger-note i {
                flex-shrink: 0;
                margin-top: 1px;
            }

        /* Global button atoms */
        .dc-btn-primary {
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: 10px 18px;
            font-size: 13px;
            font-weight: 600;
            font-family: inherit;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            cursor: pointer;
            transition: background var(--dur), box-shadow var(--dur), transform var(--dur);
        }

            .dc-btn-primary:hover {
                background: var(--primary-dk);
                box-shadow: 0 4px 12px rgba(59,130,246,.3);
                transform: translateY(-1px);
            }

            .dc-btn-primary:active {
                transform: scale(.98);
            }

        .dc-btn-outline {
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 9px 16px;
            font-size: 13px;
            font-weight: 500;
            font-family: inherit;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            cursor: pointer;
            transition: all var(--dur);
        }

            .dc-btn-outline:hover {
                background: var(--bg);
                color: var(--text);
            }

        .dc-page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .dc-page-title {
            font-size: 22px;
            font-weight: 700;
            color: var(--text);
        }

        .dc-page-sub {
            font-size: 13px;
            color: var(--text-muted);
            margin-top: 3px;
        }
    </style>


    <!-- ── Page Header ── -->
    <div class="dc-page-header">
        <div>
            <h1 class="dc-page-title">Doktor Yönetimi</h1>
            <p class="dc-page-sub">Tüm doktorları ve uzmanları yönetin, randevu ve profil işlemlerini gerçekleştirin</p>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
