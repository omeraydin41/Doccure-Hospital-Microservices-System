              name:'Nilüfer Çetin', meta:'Kadın · 33 yaş · #H-0934',
              branch:'Dermatoloji', doctor:'Dr. Selin Arslan',
              blood:'AB Rh-', lastvisit:'25 Nis 2026 · 10:00',
              phone:'0544 *** 55 89', insurance:'SGK',
              status:'active',
              diagnosis:'Psöriazis plak tip. Topikal kortikosteroid tedavisi ve nemlendiriciye yanıt iyi. Takip devam ediyor.',
              history:[
                {date:'25 Nis 2026', text:'Dermatoloji kontrol', doctor:'Dr. S. Arslan', color:'var(--success)'},
                {date:'11 Mar 2026', text:'İlk başvuru — cilt döküntüsü', doctor:'Dr. S. Arslan', color:'var(--primary)'},
              ],
              rx:['Betametazon %0.1 krem', 'Urea %10 losyon', 'D vitamini analogu krem'],
            },
            P10: {
              av:'TD', avBg:'linear-gradient(135deg,#0EA5E9,#0284C7)',
              name:'Tarık Demir', meta:'Erkek · 55 yaş · #H-1021',
              branch:'Nöroloji', doctor:'Dr. Zeynep Kara',
              blood:'0 Rh+', lastvisit:'27 Nis 2026 · Yeni Kayıt',
              phone:'0538 *** 77 03', insurance:'SGK',
              status:'new',
              diagnosis:'İlk başvuru — sağ elde uyuşma ve titreme şikayeti. Nörolojik muayene tamamlandı, EMG istemi yapıldı.',
              history:[
                {date:'27 Nis 2026', text:'İlk nöroloji muayenesi', doctor:'Dr. Z. Kara', color:'var(--success)'},
              ],
              rx:['Vitamin B12 1000mcg (enjeksiyon)'],
            },
          };

          let _statusFilter = 'all';
          let _delName = '';
          let _delRow  = null;
          let _currentPatient = '';

          /* ─ Tab ─ */
          function setTab(el) {
            document.querySelectorAll('.pt-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            _statusFilter = el.dataset.status;
            filter();
          }

          /* ─ Filter ─ */
          function filter() {
            const q = (document.getElementById('pt-search').value || '').toLowerCase().trim();
            let n = 0;
            document.querySelectorAll('.pt-row').forEach(row => {
              const statusOk = _statusFilter === 'all' || row.dataset.status === _statusFilter;
              const searchOk = row.dataset.search.includes(q);
              const show = statusOk && searchOk;
              row.style.display = show ? '' : 'none';
              if (show) n++;
            });
            const info = document.getElementById('pt-result-info');
            const sub  = document.getElementById('pt-table-sub');
            if (info) info.textContent = n + ' hasta gösteriliyor';
            if (sub)  sub.textContent  = n + ' kayıt listeleniyor';

            let empty = document.getElementById('pt-tbl-empty');
            const tbody = document.getElementById('pt-tbody');
            if (n === 0 && !empty) {
              empty = document.createElement('tr'); empty.id = 'pt-tbl-empty';
              empty.innerHTML = `<td colspan="8"><div class="pt-empty"><i class="bi bi-person-x"></i><div class="pt-empty-title">Hasta bulunamadı</div><div style="font-size:13px">Farklı arama terimi veya filtre deneyin.</div></div></td>`;
              tbody.appendChild(empty);
            } else if (n > 0 && empty) { empty.remove(); }
          }

          /* ─ Branch / Doctor filter (dummy) ─ */
          function filterBranch(v) {
            Shell.toast(v ? `${v} branşı filtrelendi.` : 'Tüm branşlar gösteriliyor.', 'info', 'bi-funnel');
          }
          function filterDoctor(v) {
            Shell.toast(v ? `${v} hastaları filtrelendi.` : 'Tüm doktorlar gösteriliyor.', 'info', 'bi-funnel');
          }

          /* ─ Sort ─ */
          function sort(by) {
            Shell.toast(`Tablo ${by === 'name' ? 'hasta adına' : by === 'age' ? 'yaşa' : 'son ziyarete'} göre sıralandı.`, 'info', 'bi-sort-down');
          }

          /* ─ Pagination ─ */
          function changePage(n) {
            document.querySelectorAll('.pt-page-btn').forEach(b => b.classList.remove('active'));
            Shell.toast(`Sayfa ${n} yükleniyor...`, 'info', 'bi-arrow-right');
          }

          /* ─ Modal helpers ─ */
          function open(id)  { document.getElementById(id).classList.add('show'); document.body.style.overflow = 'hidden'; }
          function close(id) { document.getElementById(id).classList.remove('show'); document.body.style.overflow = ''; }

          /* ─ Detail ─ */
          function openDetail(id) {
            const d = DATA[id]; if (!d) return;
            _currentPatient = d.name;

            document.getElementById('pt-d-av').textContent    = d.av;
            document.getElementById('pt-d-av').style.background = d.avBg;
            document.getElementById('pt-d-name').textContent  = d.name;
            document.getElementById('pt-d-meta').textContent  = d.meta;
            document.getElementById('pt-d-branch').textContent    = d.branch;
            document.getElementById('pt-d-doctor').textContent    = d.doctor;
            document.getElementById('pt-d-blood').textContent     = d.blood;
            document.getElementById('pt-d-lastvisit').textContent = d.lastvisit;
            document.getElementById('pt-d-phone').textContent     = d.phone;
            document.getElementById('pt-d-insurance').textContent = d.insurance;
            document.getElementById('pt-d-diagnosis').textContent = d.diagnosis;

            // Status badge
            const statusMap = {
              active: ['active','Aktif Tedavi'],
              critical: ['critical','Kritik'],
              new: ['new','Yeni Kayıt'],
              discharged: ['discharged','Taburcu'],
            };
            const [cls, label] = statusMap[d.status] || ['discharged','—'];
            document.getElementById('pt-d-badge').innerHTML =
              `<span class="pt-badge ${cls}"><i class="bi bi-circle-fill" style="font-size:6px"></i>${label}</span>`;

            // History
            const histEl = document.getElementById('pt-d-history');
            histEl.innerHTML = d.history.map(h => `
              <div class="pt-tl-item">
                <div class="pt-tl-dot" style="background:${h.color}"></div>
                <div class="pt-tl-date">${h.date}</div>
                <div class="pt-tl-text">${h.text}</div>
                <div class="pt-tl-doc">${h.doctor}</div>
              </div>`).join('');

            // Prescriptions
            const rxEl = document.getElementById('pt-d-rx');
            if (d.rx.length === 0) {
              rxEl.innerHTML = '<span style="font-size:13px;color:var(--text-muted)">Aktif reçete bulunmuyor.</span>';
            } else {
              rxEl.innerHTML = d.rx.map(r =>
                `<span class="pt-rx-chip"><i class="bi bi-capsule"></i>${r}</span>`
              ).join('');
            }

            open('pt-m-detail');
          }

          /* ─ Book appointment ─ */
          function bookAppt(name) {
            Shell.toast(`${name} için randevu oluşturuluyor...`, 'success', 'bi-calendar-plus');
          }
          function bookApptFromDetail() {
            Shell.toast(`${_currentPatient} için randevu oluşturuluyor...`, 'success', 'bi-calendar-plus');
          }

          /* ─ Add ─ */
          function openAdd() { open('pt-m-add'); }

          /* ─ Delete ─ */
          function confirmDelete(name, btn) {
            _delName = name;
            _delRow  = btn.closest('.pt-row');
            document.getElementById('pt-del-name').textContent = name;
            open('pt-m-delete');
          }
          function execDelete() {
            close('pt-m-delete');
            if (_delRow) {
              _delRow.style.transition = 'opacity .3s ease';
              _delRow.style.opacity = '0';
              setTimeout(() => { _delRow?.remove(); _delRow = null; filter(); }, 320);
            }
            Shell.toast(`${_delName} kaydı silindi.`, 'danger', 'bi-trash3');
          }

          /* ─ Export / Print ─ */
          function exportList() { Shell.toast('Hasta listesi Excel olarak hazırlanıyor...', 'info', 'bi-file-earmark-spreadsheet'); }
          function printList()  { Shell.toast('Yazdırma hazırlanıyor...', 'info', 'bi-printer'); }

          /* ─ ESC ─ */
          document.addEventListener('keydown', e => {
            if (e.key === 'Escape')
              document.querySelectorAll('.pt-overlay.show').forEach(m => close(m.id));
          });

          /* ─ Init ─ */
          if (typeof Shell !== 'undefined' && Shell.setPage)
            Shell.setPage('Hastalar', 'Admin Paneli / Klinik / Hastalar');

          return { setTab, filter, filterBranch, filterDoctor, sort, changePage, openDetail, bookAppt, bookApptFromDetail, openAdd, confirmDelete, execDelete, exportList, printList, close };
        })();
    </script>

</main>
