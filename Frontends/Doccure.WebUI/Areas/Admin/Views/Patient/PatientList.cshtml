
@{
    ViewData["Title"] = "PatientList";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

﻿<main id="app-content">

    <style>
        /* ── Stat Strip ── */
        .pt-stat-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 14px;
            margin-bottom: 24px;
        }
        @@media(max - width:900px) {
            .pt-stat-grid

        {
            grid-template-columns: repeat(2,1fr)
        }

        }
        @@media(max - width:480px) {
            .pt-stat-grid

        {
            grid-template-columns: 1fr 1fr;
            gap: 10px
        }

        }

        .pt-stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            box-shadow: var(--shadow);
            transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
        }

            .pt-stat-card:hover {
                box-shadow: 0 4px 20px rgba(59,130,246,.13);
                transform: translateY(-2px);
            }

        .pt-si {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 19px;
        }

        .pt-si-blue {
            background: var(--primary-bg);
            color: var(--primary);
        }

        .pt-si-green {
            background: var(--success-bg);
            color: var(--success);
        }

        .pt-si-orange {
            background: var(--warning-bg);
            color: var(--warning);
        }

        .pt-si-purple {
            background: #F3F0FF;
            color: #7C3AED;
        }

        .pt-stat-val {
            font-size: 22px;
            font-weight: 700;
            color: var(--text);
            line-height: 1.1;
        }

        .pt-stat-lbl {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 500;
            margin-top: 2px;
        }

        .pt-stat-sub {
            font-size: 11px;
            font-weight: 600;
            margin-top: 4px;
        }

            .pt-stat-sub.up {
                color: var(--success);
            }

            .pt-stat-sub.down {
                color: var(--danger);
            }

        /* ── Toolbar ── */
        .pt-toolbar {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 14px 18px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .pt-search-wrap {
            position: relative;
            flex: 1;
            min-width: 200px;
            max-width: 340px;
        }

            .pt-search-wrap i {
                position: absolute;
                left: 11px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 13px;
                pointer-events: none;
            }

            .pt-search-wrap input {
                width: 100%;
                border: 1px solid var(--border);
                border-radius: 20px;
                padding: 9px 14px 9px 33px;
                font-size: 13px;
                font-family: inherit;
                background: var(--bg);
                color: var(--text);
                outline: none;
                transition: border-color var(--dur), box-shadow var(--dur);
            }

                .pt-search-wrap input:focus {
                    border-color: var(--primary);
                    box-shadow: 0 0 0 3px rgba(59,130,246,.1);
                    background: #fff;
                }

                .pt-search-wrap input::placeholder {
                    color: var(--text-muted);
                }

        .pt-select {
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 8px 12px;
            font-size: 12px;
            font-family: inherit;
            background: var(--surface);
            color: var(--text);
            outline: none;
            cursor: pointer;
            transition: border-color var(--dur);
        }

            .pt-select:focus {
                border-color: var(--primary);
            }

        .pt-tabs {
            display: flex;
            gap: 5px;
        }

        .pt-tab {
            border: 1px solid var(--border);
            background: var(--surface);
            border-radius: 20px;
            padding: 7px 14px;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            cursor: pointer;
            transition: all var(--dur);
            white-space: nowrap;
        }

            .pt-tab:hover {
                background: var(--primary-bg);
                color: var(--primary);
                border-color: #C7D9F8;
            }

            .pt-tab.active {
                background: var(--primary);
                color: #fff;
                border-color: var(--primary);
            }

        /* ── Table Card ── */
        .pt-table-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .pt-table-header {
            padding: 14px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .pt-table-title {
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
        }

        .pt-table-sub {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        /* ── Table ── */
        .pt-tbl {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

            .pt-tbl th {
                padding: 10px 16px;
                text-align: left;
                font-size: 10.5px;
                font-weight: 700;
                letter-spacing: .07em;
                text-transform: uppercase;
                color: var(--text-muted);
                background: var(--bg);
                border-bottom: 1px solid var(--border);
                white-space: nowrap;
                user-select: none;
            }

                .pt-tbl th.sortable {
                    cursor: pointer;
                }

                    .pt-tbl th.sortable:hover {
                        color: var(--primary);
                    }

                .pt-tbl th i {
                    font-size: 10px;
                    margin-left: 3px;
                    opacity: .5;
                }

            .pt-tbl td {
                padding: 13px 16px;
                border-bottom: 1px solid var(--border);
                vertical-align: middle;
            }

            .pt-tbl tbody tr:last-child td {
                border-bottom: none;
            }

            .pt-tbl tbody tr {
                transition: background var(--dur);
                cursor: pointer;
            }

                .pt-tbl tbody tr:hover {
                    background: #F8FAFF;
                }

        /* Patient cell */
        .pt-patient-cell {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .pt-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            color: #fff;
        }

        .pt-patient-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }

        .pt-patient-id {
            font-size: 10.5px;
            color: var(--text-muted);
            margin-top: 1px;
        }

        /* Badges */
        .pt-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 9px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            white-space: nowrap;
        }

            .pt-badge.active {
                background: var(--success-bg);
                color: #065F46;
            }

            .pt-badge.check {
                background: var(--primary-bg);
                color: var(--primary-dk);
            }

            .pt-badge.critical {
                background: var(--danger-bg);
                color: #991B1B;
            }

            .pt-badge.discharged {
                background: #F1F5F9;
                color: #475569;
            }

            .pt-badge.new {
                background: var(--warning-bg);
                color: #92400E;
            }

        /* Action btn */
        .pt-action-btn {
            width: 28px;
            height: 28px;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: transparent;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: var(--text-muted);
            cursor: pointer;
            transition: all var(--dur);
            margin-right: 3px;
        }

            .pt-action-btn:hover {
                background: var(--primary-bg);
                color: var(--primary);
                border-color: #C7D9F8;
            }

            .pt-action-btn.danger:hover {
                background: var(--danger-bg);
                color: var(--danger);
                border-color: #FCA5A5;
            }

        /* ── Pagination ── */
        .pt-pagination {
            padding: 14px 20px;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .pt-page-info {
            font-size: 12px;
            color: var(--text-muted);
        }

        .pt-pages {
            display: flex;
            gap: 4px;
        }

        .pt-page-btn {
            width: 32px;
            height: 32px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            background: transparent;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            cursor: pointer;
            transition: all var(--dur);
        }

            .pt-page-btn:hover {
                background: var(--primary-bg);
                color: var(--primary);
                border-color: #C7D9F8;
            }

            .pt-page-btn.active {
                background: var(--primary);
                color: #fff;
                border-color: var(--primary);
            }

            .pt-page-btn:disabled {
                opacity: .35;
                cursor: not-allowed;
            }

        /* ── Empty ── */
        .pt-empty {
            padding: 64px 24px;
            text-align: center;
            color: var(--text-muted);
        }

            .pt-empty i {
                font-size: 46px;
                opacity: .15;
                display: block;
                margin-bottom: 14px;
            }

        .pt-empty-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 6px;
        }

        /* ── Detail Modal ── */
        .pt-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,.45);
            z-index: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
            opacity: 0;
            pointer-events: none;
            transition: opacity .2s ease;
        }

            .pt-overlay.show {
                opacity: 1;
                pointer-events: all;
            }

        .pt-modal-box {
            background: var(--surface);
            border-radius: var(--radius);
            box-shadow: 0 20px 60px rgba(0,0,0,.18);
            width: 100%;
            max-width: 560px;
            transform: scale(.93) translateY(16px);
            transition: transform .26s cubic-bezier(.34,1.56,.64,1);
            max-height: 90vh;
            display: flex;
            flex-direction: column;
        }

        .pt-overlay.show .pt-modal-box {
            transform: scale(1) translateY(0);
        }

        /* Modal hero */
        .pt-modal-hero {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 20px 24px;
            border-bottom: 1px solid var(--border);
            background: linear-gradient(135deg,#EFF6FF 0%,#F8FAFC 100%);
            flex-shrink: 0;
        }

        .pt-modal-av {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 700;
            color: #fff;
            border: 3px solid #fff;
            box-shadow: 0 4px 14px rgba(0,0,0,.12);
        }

        .pt-modal-name {
            font-size: 17px;
            font-weight: 700;
            color: var(--text);
        }

        .pt-modal-id {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .pt-modal-close {
            margin-left: auto;
            align-self: flex-start;
            width: 30px;
            height: 30px;
            border: 1px solid var(--border);
            background: transparent;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: var(--text-muted);
            cursor: pointer;
            flex-shrink: 0;
            transition: background var(--dur);
        }

            .pt-modal-close:hover {
                background: rgba(0,0,0,.06);
            }

        /* Modal body */
        .pt-modal-body {
            padding: 0;
            overflow-y: auto;
            flex: 1;
        }

        /* Info grid */
        .pt-info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
            border-bottom: 1px solid var(--border);
        }

        .pt-info-cell {
            padding: 13px 22px;
            border-right: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }

            .pt-info-cell:nth-child(even) {
                border-right: none;
            }

            .pt-info-cell:nth-last-child(-n+2) {
                border-bottom: none;
            }

        .pt-info-lbl {
            font-size: 10.5px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: .05em;
            margin-bottom: 4px;
        }

        .pt-info-val {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }

        /* Section */
        .pt-modal-section {
            padding: 16px 22px;
            border-bottom: 1px solid var(--border);
        }

            .pt-modal-section:last-child {
                border-bottom: none;
            }

        .pt-section-title {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .07em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 12px;
        }

        /* Timeline items */
        .pt-tl-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 0;
            border-bottom: 1px dashed var(--border);
        }

            .pt-tl-item:last-child {
                border-bottom: none;
                padding-bottom: 0;
            }

        .pt-tl-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .pt-tl-date {
            font-size: 11px;
            color: var(--text-muted);
            white-space: nowrap;
            min-width: 90px;
        }

        .pt-tl-text {
            font-size: 12px;
            font-weight: 500;
            color: var(--text);
        }

        .pt-tl-doc {
            font-size: 11px;
            color: var(--text-muted);
            margin-left: auto;
            white-space: nowrap;
        }

        /* Prescription chips */
        .pt-rx-chip {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 500;
            color: var(--text);
            margin: 3px;
        }

            .pt-rx-chip i {
                color: var(--primary);
                font-size: 12px;
            }

        /* Modal footer */
        .pt-modal-footer {
            padding: 14px 22px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 8px;
            flex-shrink: 0;
        }

        /* Global btn atoms */
        .pt-btn-primary {
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: 10px 18px;
            font-size: 13px;
            font-weight: 600;
            font-family: inherit;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            cursor: pointer;
            transition: background var(--dur), box-shadow var(--dur), transform var(--dur);
        }

            .pt-btn-primary:hover {
                background: var(--primary-dk);
                box-shadow: 0 4px 12px rgba(59,130,246,.3);
                transform: translateY(-1px);
            }

        .pt-btn-outline {
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 9px 16px;
            font-size: 13px;
            font-weight: 500;
            font-family: inherit;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            cursor: pointer;
            transition: all var(--dur);
        }

            .pt-btn-outline:hover {
                background: var(--bg);
                color: var(--text);
            }

        .pt-page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .pt-page-title {
            font-size: 22px;
            font-weight: 700;
            color: var(--text);
        }

        .pt-page-sub {
            font-size: 13px;
            color: var(--text-muted);
            margin-top: 3px;
        }
    </style>


    <!-- ── Page Header ── -->
    <div class="pt-page-header">
        <div>
            <h1 class="pt-page-title">Hasta Yönetimi</h1>
            <p class="pt-page-sub">Kayıtlı hastaları görüntüleyin, filtreleyin ve hasta detaylarına erişin</p>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
            <button class="pt-btn-outline" onclick="PT.exportList()"><i class="bi bi-download"></i> Dışa Aktar</button>
            <button class="pt-btn-primary" onclick="PT.openAdd()"><i class="bi bi-person-plus"></i> Yeni Hasta</button>
        </div>
    </div>

    <!-- ── Stat Strip ── -->
    <div class="pt-stat-grid">
        <div class="pt-stat-card">
            <div class="pt-si pt-si-blue"><i class="bi bi-people"></i></div>
            <div>
                <div class="pt-stat-val">1.284</div>
                <div class="pt-stat-lbl">Toplam Hasta</div>
                <div class="pt-stat-sub up"><i class="bi bi-arrow-up-short"></i>+38 bu ay</div>
            </div>
        </div>
        <div class="pt-stat-card">
            <div class="pt-si pt-si-green"><i class="bi bi-calendar-check"></i></div>
            <div>
                <div class="pt-stat-val">24</div>
                <div class="pt-stat-lbl">Bugün Gelen</div>
                <div class="pt-stat-sub up">Devam ediyor</div>
            </div>
        </div>
        <div class="pt-stat-card">
            <div class="pt-si pt-si-orange"><i class="bi bi-hospital"></i></div>
            <div>
                <div class="pt-stat-val">47</div>
                <div class="pt-stat-lbl">Aktif Tedavi</div>
                <div class="pt-stat-sub down"><i class="bi bi-arrow-down-short"></i>3 kritik</div>
            </div>
        </div>
        <div class="pt-stat-card">
            <div class="pt-si pt-si-purple"><i class="bi bi-box-arrow-right"></i></div>
            <div>
                <div class="pt-stat-val">12</div>
                <div class="pt-stat-lbl">Bu Hafta Taburcu</div>
                <div class="pt-stat-sub up"><i class="bi bi-arrow-up-short"></i>+4 geçen haftaya göre</div>
            </div>
        </div>
    </div>

    <!-- ── Toolbar ── -->
    <div class="pt-toolbar">
        <div class="pt-search-wrap">
            <i class="bi bi-search"></i>
            <input id="pt-search" placeholder="İsim, TC veya hasta ID ile ara..." oninput="PT.filter()">
        </div>
        <select class="pt-select" onchange="PT.filterBranch(this.value)">
            <option value="">Tüm Branşlar</option>
            <option>Kardiyoloji</option>
            <option>Dermatoloji</option>
            <option>Ortopedi</option>
            <option>Nöroloji</option>
            <option>Pediatri</option>
            <option>Radyoloji</option>
        </select>
        <select class="pt-select" onchange="PT.filterDoctor(this.value)">
            <option value="">Tüm Doktorlar</option>
            <option>Dr. Mehmet Demir</option>
            <option>Dr. Selin Arslan</option>
            <option>Dr. Can Öztürk</option>
            <option>Dr. Zeynep Kara</option>
            <option>Dr. Ahmet Yılmaz</option>
        </select>
        <div class="pt-tabs">
            <button class="pt-tab active" data-status="all" onclick="PT.setTab(this)">Tümü</button>
            <button class="pt-tab" data-status="active" onclick="PT.setTab(this)">Aktif</button>
            <button class="pt-tab" data-status="critical" onclick="PT.setTab(this)">Kritik</button>
            <button class="pt-tab" data-status="new" onclick="PT.setTab(this)">Yeni</button>
            <button class="pt-tab" data-status="discharged" onclick="PT.setTab(this)">Taburcu</button>
        </div>
        <div style="margin-left:auto;font-size:12px;color:var(--text-muted)" id="pt-result-info">13 hasta gösteriliyor</div>
    </div>

    <!-- ── Table Card ── -->
    <div class="pt-table-card">
        <div class="pt-table-header">
            <div>
                <div class="pt-table-title">Hasta Listesi</div>
                <div class="pt-table-sub" id="pt-table-sub">Tüm kayıtlı hastalar</div>
            </div>
            <div style="display:flex;gap:6px">
                <button class="pt-btn-outline" style="padding:7px 12px;font-size:12px" onclick="PT.exportList()">
                    <i class="bi bi-file-earmark-excel"></i> Excel
                </button>
                <button class="pt-btn-outline" style="padding:7px 12px;font-size:12px" onclick="PT.printList()">
                    <i class="bi bi-printer"></i> Yazdır
                </button>
            </div>
        </div>

        <div style="overflow-x:auto">
            <table class="pt-tbl">
                <thead>
                    <tr>
                        <th class="sortable" onclick="PT.sort('name')">Hasta <i class="bi bi-arrow-down-up"></i></th>
                        <th>TC / ID</th>
                        <th class="sortable" onclick="PT.sort('age')">Yaş <i class="bi bi-arrow-down-up"></i></th>
                        <th>Branş</th>
                        <th>Sorumlu Doktor</th>
                        <th class="sortable" onclick="PT.sort('date')">Son Ziyaret <i class="bi bi-arrow-down-up"></i></th>
                        <th>Durum</th>
                        <th style="text-align:center">İşlem</th>
                    </tr>
                </thead>
                <tbody id="pt-tbody">

                    <tr class="pt-row" data-status="active" data-search="ayşe kaya kardiyoloji mehmet demir" onclick="PT.openDetail('P01')">
