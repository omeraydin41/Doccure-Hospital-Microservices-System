    <div class="bc-overlay" id="bc-m-delete" onclick="if(event.target===this)BC.close('bc-m-delete')">
        <div class="bc-modal-box" style="max-width:420px">
            <div class="bc-modal-header">
                <div class="bc-modal-title" style="color:var(--danger)">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Branşı Sil
                </div>
                <button class="bc-modal-close" onclick="BC.close('bc-m-delete')"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="bc-modal-body">
                <p style="font-size:14px;line-height:1.7;color:var(--text)">
                    <strong id="bc-del-name" style="color:var(--danger)"></strong> branşını kalıcı olarak silmek istediğinizden emin misiniz?
                </p>
                <div class="bc-modal-danger-note">
                    <i class="bi bi-info-circle-fill"></i>
                    Bu işlem geri alınamaz. Branşa ait randevu ve kayıtlar arşive taşınır.
                </div>
            </div>
            <div class="bc-modal-footer">
                <button class="bc-btn-outline" onclick="BC.close('bc-m-delete')">Vazgeç</button>
                <button class="bc-btn-primary" style="background:var(--danger)" onclick="BC.execDelete()">
                    <i class="bi bi-trash3"></i> Evet, Sil
                </button>
            </div>
        </div>
    </div>

    <!-- Yeni Branş (placeholder) -->
    <div class="bc-overlay" id="bc-m-add" onclick="if(event.target===this)BC.close('bc-m-add')">
        <div class="bc-modal-box" style="max-width:440px">
            <div class="bc-modal-header">
                <div class="bc-modal-title"><i class="bi bi-plus-circle me-2" style="color:var(--primary)"></i>Yeni Branş Ekle</div>
                <button class="bc-modal-close" onclick="BC.close('bc-m-add')"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="bc-modal-body" style="text-align:center;padding:36px 24px">
                <i class="bi bi-layout-text-window-reverse" style="font-size:44px;color:var(--primary);opacity:.2;display:block;margin-bottom:14px"></i>
                <div style="font-size:15px;font-weight:700;margin-bottom:6px">Sayfa henüz bağlanmadı</div>
                <p style="font-size:13px;color:var(--text-muted);line-height:1.7">
                    Yeni branş ekleme sayfanızı oluşturup<br>bu modal içeriğini kendi formunuzla değiştirin.
                </p>
            </div>
            <div class="bc-modal-footer">
                <button class="bc-btn-outline" onclick="BC.close('bc-m-add')">Kapat</button>
                <button class="bc-btn-primary" onclick="BC.close('bc-m-add');Shell.toast('Ekleme sayfasına yönlendiriliyor...','info','bi-arrow-right-circle')">
                    <i class="bi bi-box-arrow-up-right"></i> Sayfaya Git
                </button>
            </div>
        </div>
    </div>


    <!-- ── PAGE JS ── -->
    <script>
        const BC = (() => {
          let _cat  = 'all';
          let _delName = '';
          let _delCard = null;

          /* ─ View ─ */
          function setView(v) {
            document.getElementById('bc-grid').classList.toggle('list-mode', v === 'list');
            document.getElementById('bc-vg').classList.toggle('active', v === 'grid');
            document.getElementById('bc-vl').classList.toggle('active', v === 'list');
            if (v === 'list') _closeAllExpand();
          }

          /* ─ Tab ─ */
          function setTab(el) {
            document.querySelectorAll('.bc-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            _cat = el.dataset.cat;
            filter();
          }

          /* ─ Filter ─ */
          function filter() {
            const q = (document.getElementById('bc-search').value || '').toLowerCase().trim();
            let n = 0;
            document.querySelectorAll('#bc-grid .bc-card').forEach(c => {
              const show = (_cat === 'all' || c.dataset.cat === _cat) && c.dataset.name.includes(q);
              c.style.display = show ? '' : 'none';
              if (show) n++;
            });
            const cnt = document.getElementById('bc-count');
            if (cnt) cnt.textContent = n;
            let empty = document.getElementById('bc-empty');
            if (n === 0 && !empty) {
              empty = document.createElement('div');
              empty.id = 'bc-empty'; empty.className = 'bc-empty';
              empty.innerHTML = '<i class="bi bi-search"></i><div class="bc-empty-title">Sonuç bulunamadı</div><div style="font-size:13px">Farklı arama terimi veya kategori deneyin.</div>';
              document.getElementById('bc-grid').appendChild(empty);
            } else if (n > 0 && empty) { empty.remove(); }
          }

          /* ─ Docs expand ─ */
          function toggleDocs(i, btn) {
            const panel = document.getElementById('bc-exp-' + i);
            const open  = panel.classList.contains('open');
            _closeAllExpand();
            if (!open) {
              panel.classList.add('open');
              btn.innerHTML = '<i class="bi bi-chevron-up"></i> Gizle';
            }
          }
          function _closeAllExpand() {
            document.querySelectorAll('.bc-expand.open').forEach(p => p.classList.remove('open'));
            document.querySelectorAll('.bc-btn.primary[onclick^="BC.toggleDocs"]').forEach(b => {
              b.innerHTML = '<i class="bi bi-people"></i> Doktorlar';
            });
          }

          /* ─ Appointment ─ */
          function book(doc) {
            Shell.toast(`${doc} için randevu talebi oluşturuldu!`, 'success', 'bi-calendar-check');
          }

          /* ─ Modal helpers ─ */
          function open(id) {
            document.getElementById(id).classList.add('show');
            document.body.style.overflow = 'hidden';
          }
          function close(id) {
            document.getElementById(id).classList.remove('show');
            document.body.style.overflow = '';
          }

          /* ─ Add ─ */
          function openAdd() { open('bc-m-add'); }

          /* ─ Edit ─ */
          function openEdit(d) {
            document.getElementById('bc-edit-name').value = d.name || '';
            document.getElementById('bc-edit-desc').value = d.desc || '';
            document.getElementById('bc-edit-docs').value = d.docs || '';
            document.getElementById('bc-edit-code').textContent = 'Kod: ' + (d.code || '');
            document.getElementById('bc-edit-cat').value = d.cat || 'dahili';
            open('bc-m-edit');
          }
          function saveEdit() {
            const n = document.getElementById('bc-edit-name').value.trim();
            if (!n) { Shell.toast('Branş adı boş olamaz!', 'danger', 'bi-exclamation-circle'); return; }
            close('bc-m-edit');
            Shell.toast(`"${n}" branşı güncellendi.`, 'success', 'bi-check-circle');
          }

          /* ─ Delete ─ */
          function confirmDelete(name, btn) {
            _delName = name;
            _delCard = btn.closest('.bc-card');
            document.getElementById('bc-del-name').textContent = name;
            open('bc-m-delete');
          }
          function execDelete() {
            close('bc-m-delete');
            if (_delCard) {
              _delCard.style.transition = 'opacity .3s ease, transform .3s ease';
              _delCard.style.opacity = '0';
              _delCard.style.transform = 'scale(.94)';
              setTimeout(() => { _delCard?.remove(); _delCard = null; filter(); }, 320);
            }
            Shell.toast(`"${_delName}" branşı silindi.`, 'danger', 'bi-trash3');
          }

          /* ─ Export ─ */
          function exportList() {
            Shell.toast('Branş listesi Excel olarak hazırlanıyor...', 'info', 'bi-file-earmark-spreadsheet');
          }

          /* ─ ESC ─ */
          document.addEventListener('keydown', e => {
            if (e.key === 'Escape')
              document.querySelectorAll('.bc-overlay.show').forEach(m => close(m.id));
          });

          /* ─ Topbar başlığını güncelle ─ */
          if (typeof Shell !== 'undefined' && Shell.setPage)
            Shell.setPage('Branşlar', 'Admin Paneli / Klinik / Branşlar');

          return { setView, setTab, filter, toggleDocs, book, openAdd, openEdit, saveEdit, confirmDelete, execDelete, exportList, close };
        })();
    </script>

</main>