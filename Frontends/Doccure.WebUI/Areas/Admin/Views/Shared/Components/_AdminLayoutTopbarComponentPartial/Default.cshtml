﻿<header id="topbar">

    <!-- Sidebar toggle -->
    <button class="tb-toggle" id="sidebar-toggle" title="Menüyü Aç/Kapat">
        <i class="bi bi-list"></i>
    </button>

    <!-- Breadcrumb -->
    <div class="tb-breadcrumb">
        <div class="tb-page-title" id="tb-title">Branşlar</div>
        <div class="tb-page-path" id="tb-path">Admin Paneli / Klinik / Branşlar</div>
    </div>

    <div class="tb-divider d-none d-md-block"></div>

    <!-- Arama -->
    <div class="tb-search-wrap">
        <i class="bi bi-search"></i>
        <input class="tb-search" id="tb-search" placeholder="Hasta, doktor, randevu ara...">
    </div>

    <!-- Sistem durumu -->
    <div class="tb-status-chip d-none d-lg-flex" title="Sistem çevrimiçi">
        <span class="live-dot"></span>
        Sistem Aktif
    </div>

    <!-- Tarih -->
    <div class="tb-date d-none d-xl-block" id="tb-date"></div>

    <div class="tb-divider d-none d-lg-block"></div>

    <!-- Acil çağrı -->
    <button class="tb-emergency-btn" onclick="Shell.toast('Acil çağrı merkezi ile bağlantı kuruluyor...','danger','bi-telephone-fill')">
        <i class="bi bi-telephone-fill"></i>
        Acil Çağrı
    </button>

    <!-- Hızlı işlem butonları -->
    <div class="tb-actions">

        <!-- Yeni randevu -->
        <button class="tb-icon-btn" title="Yeni Randevu Oluştur" onclick="Shell.toast('Yeni randevu formu açılıyor...','info','bi-calendar-plus')">
            <i class="bi bi-calendar-plus"></i>
        </button>

        <!-- Bildirimler -->
        <div class="dropdown">
            <button class="tb-icon-btn dropdown-toggle" title="Bildirimler" data-bs-toggle="dropdown">
                <i class="bi bi-bell"></i>
                <span class="dot red"></span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end" style="min-width:280px">
                <li><h6 class="dropdown-header">Bildirimler</h6></li>
                <li>
                    <a class="dropdown-item" href="#">
                        <div style="font-size:12.5px;font-weight:600">2 Yeni randevu talebi</div>
                        <div style="font-size:11px;color:var(--text-muted)">Kardiyoloji · 5 dakika önce</div>
                    </a>
                </li>
                <li>
                    <a class="dropdown-item" href="#">
                        <div style="font-size:12.5px;font-weight:600">Lab sonuçları hazır</div>
                        <div style="font-size:11px;color:var(--text-muted)">Hasta #H-1042 · 12 dakika önce</div>
                    </a>
                </li>
                <li>
                    <a class="dropdown-item" href="#">
                        <div style="font-size:12.5px;font-weight:600">Nöbet değişikliği onayı</div>
                        <div style="font-size:11px;color:var(--text-muted)">Dr. Mehmet Demir · 1 saat önce</div>
                    </a>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-center" href="#" style="font-size:12px;color:var(--primary)">Tüm bildirimleri gör</a></li>
            </ul>
        </div>

        <!-- Mesajlar -->
        <button class="tb-icon-btn" title="Mesajlar" onclick="Shell.toast('Mesajlar açılıyor...','info','bi-chat-dots')">
            <i class="bi bi-chat-dots"></i>
            <span class="dot orange"></span>
        </button>

        <!-- Tam ekran -->
        <button class="tb-icon-btn d-none d-md-flex" title="Tam Ekran" id="fullscreen-btn">
            <i class="bi bi-arrows-fullscreen"></i>
        </button>

    </div>

    <div class="tb-divider"></div>

    <!-- Profil -->
    <div class="tb-profile-wrap dropdown">
        <button class="tb-profile-btn dropdown-toggle" data-bs-toggle="dropdown">
            <div class="tb-profile-av">AD</div>
            <div>
                <div class="tb-profile-name">Admin Kullanıcı</div>
                <div class="tb-profile-role">Yönetici</div>
            </div>
        </button>
        <ul class="dropdown-menu dropdown-menu-end" style="min-width:200px">
            <li><h6 class="dropdown-header">Hesabım</h6></li>
            <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>Profilim</a></li>
            <li><a class="dropdown-item" href="#"><i class="bi bi-shield-check me-2"></i>Güvenlik</a></li>
            <li><a class="dropdown-item" href="#"><i class="bi bi-sliders me-2"></i>Ayarlar</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="#"><i class="bi bi-moon me-2"></i>Koyu Tema</a></li>
            <li><a class="dropdown-item" href="#"><i class="bi bi-translate me-2"></i>Dil: Türkçe</a></li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <a class="dropdown-item text-danger" href="#"
                   onclick="Shell.toast('Çıkış yapıldı.','danger','bi-box-arrow-right');return false">
                    <i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap
                </a>
            </li>
        </ul>
    </div>

</header>