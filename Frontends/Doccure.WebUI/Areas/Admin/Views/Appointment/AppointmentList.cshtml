
@{
    ViewData["Title"] = "AppointmentList";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

﻿<main id="app-content">

    <style>
        /* ── Stat Grid ── */
        .rv-stat-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 14px;
            margin-bottom: 24px;
        }
        @@media(max - width:900px) {
            .rv-stat-grid

        {
            grid-template-columns: repeat(2,1fr)
        }

        }
        @@media(max - width:480px) {
            .rv-stat-grid

        {
            grid-template-columns: 1fr 1fr;
            gap: 10px
        }

        }

        .rv-stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            box-shadow: var(--shadow);
            transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
        }

            .rv-stat-card:hover {
                box-shadow: 0 4px 20px rgba(59,130,246,.13);
                transform: translateY(-2px);
            }

        .rv-si {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 19px;
        }

        .rv-si-blue {
            background: var(--primary-bg);
            color: var(--primary);
        }

        .rv-si-green {
            background: var(--success-bg);
            color: var(--success);
        }

        .rv-si-orange {
            background: var(--warning-bg);
            color: var(--warning);
        }

        .rv-si-red {
            background: var(--danger-bg);
            color: var(--danger);
        }

        .rv-stat-val {
            font-size: 22px;
            font-weight: 700;
            color: var(--text);
            line-height: 1.1;
        }

        .rv-stat-lbl {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 500;
            margin-top: 2px;
        }

        .rv-stat-sub {
            font-size: 11px;
            font-weight: 600;
            margin-top: 4px;
        }

            .rv-stat-sub.up {
                color: var(--success);
            }

            .rv-stat-sub.down {
                color: var(--danger);
            }

        /* ── Layout ── */
        .rv-layout {
            display: grid;
            grid-template-columns: 272px 1fr;
            gap: 18px;
            align-items: start;
        }
        @@media(max - width:960px) {
            .rv-layout

        {
            grid-template-columns: 1fr
        }

        }

        /* ── LEFT ── */
        .rv-left {
            display: flex;
            flex-direction: column;
            gap: 16px;
            position: sticky;
            top: calc(var(--topbar-h) + 16px);
        }

        .rv-cal {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .rv-cal-head {
            background: linear-gradient(135deg,var(--primary),var(--primary-dk));
            padding: 15px 18px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .rv-cal-month {
            font-size: 15px;
            font-weight: 700;
            color: #fff;
        }

        .rv-cal-nav {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,.3);
            background: rgba(255,255,255,.12);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: #fff;
            cursor: pointer;
            transition: background var(--dur);
        }

            .rv-cal-nav:hover {
                background: rgba(255,255,255,.28);
            }

        .rv-cal-body {
            padding: 12px 14px 14px;
        }

        .rv-cal-dow {
            display: grid;
            grid-template-columns: repeat(7,1fr);
            margin-bottom: 4px;
        }

            .rv-cal-dow span {
                text-align: center;
                font-size: 10px;
                font-weight: 700;
                color: var(--text-muted);
                letter-spacing: .04em;
                padding: 4px 0;
            }

        .rv-cal-days {
            display: grid;
            grid-template-columns: repeat(7,1fr);
            gap: 2px;
        }

        .rv-day {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 500;
            border-radius: 8px;
            cursor: pointer;
            color: var(--text);
            position: relative;
            transition: background var(--dur), color var(--dur);
        }

            .rv-day:hover {
                background: var(--primary-bg);
                color: var(--primary);
            }

            .rv-day.other {
                color: var(--text-muted);
                opacity: .35;
                cursor: default;
            }

                .rv-day.other:hover {
                    background: transparent;
                    color: var(--text-muted);
                }

            .rv-day.today {
                font-weight: 700;
                color: var(--primary);
            }

            .rv-day.selected {
                background: var(--primary);
                color: #fff !important;
                font-weight: 700;
            }

                .rv-day.selected:hover {
                    background: var(--primary-dk);
                }

            .rv-day.has-dot::after {
                content: '';
                position: absolute;
                bottom: 2px;
                left: 50%;
                transform: translateX(-50%);
                width: 4px;
                height: 4px;
                border-radius: 50%;
            }

            .rv-day.c-ok::after {
                background: var(--success);
            }

            .rv-day.c-pend::after {
                background: var(--warning);
            }

            .rv-day.c-busy::after {
                background: var(--danger);
            }

            .rv-day.selected.has-dot::after {
                background: #fff;
            }

        .rv-cal-legend {
            border-top: 1px solid var(--border);
            padding: 11px 16px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 7px;
        }

        .rv-legend-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 500;
        }

        .rv-legend-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        /* Today list */
        .rv-today-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .rv-today-head {
            padding: 13px 16px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .rv-today-title {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
        }

        .rv-today-date {
            font-size: 11px;
            color: var(--text-muted);
        }

        .rv-today-body {
            padding: 10px 12px;
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .rv-slot {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 10px;
            border-radius: var(--radius-sm);
            background: var(--bg);
            border: 1px solid var(--border);
            cursor: pointer;
            transition: all var(--dur);
        }

            .rv-slot:hover {
                border-color: #C7D9F8;
                background: var(--primary-bg);
            }

        .rv-slot-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .rv-slot-time {
            font-size: 11px;
            font-weight: 700;
            color: var(--text);
            white-space: nowrap;
            min-width: 36px;
        }

        .rv-slot-name {
            font-size: 12px;
            font-weight: 600;
            color: var(--text);
            flex: 1;
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .rv-slot-doc {
            font-size: 10px;
            color: var(--text-muted);
            white-space: nowrap;
        }

        .rv-slot-mark {
            font-size: 10px;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 20px;
            flex-shrink: 0;
        }

        /* ── RIGHT ── */
        .rv-right {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        /* Toolbar */
        .rv-toolbar {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 13px 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .rv-search {
            position: relative;
            flex: 1;
            min-width: 180px;
            max-width: 280px;
        }

            .rv-search i {
                position: absolute;
                left: 11px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 13px;
                pointer-events: none;
            }

            .rv-search input {
                width: 100%;
                border: 1px solid var(--border);
                border-radius: 20px;
                padding: 8px 14px 8px 32px;
                font-size: 13px;
                font-family: inherit;
                background: var(--bg);
                color: var(--text);
                outline: none;
                transition: border-color var(--dur), box-shadow var(--dur);
            }

                .rv-search input:focus {
                    border-color: var(--primary);
                    box-shadow: 0 0 0 3px rgba(59,130,246,.1);
                    background: #fff;
                }

                .rv-search input::placeholder {
                    color: var(--text-muted);
                }

        .rv-select {
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 8px 12px;
            font-size: 12px;
            font-family: inherit;
            background: var(--surface);
            color: var(--text);
            outline: none;
            cursor: pointer;
        }

        .rv-tabs {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }

        .rv-tab {
            border: 1px solid var(--border);
            background: var(--surface);
            border-radius: 20px;
            padding: 6px 13px;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            cursor: pointer;
            transition: all var(--dur);
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

            .rv-tab:hover {
                background: var(--primary-bg);
                color: var(--primary);
                border-color: #C7D9F8;
            }

            .rv-tab.active {
                background: var(--primary);
                color: #fff;
                border-color: var(--primary);
            }

        .rv-tab-n {
            font-size: 10px;
            font-weight: 700;
            padding: 1px 6px;
            border-radius: 10px;
        }

        .rv-tab.active .rv-tab-n {
            background: rgba(255,255,255,.25);
        }

        .rv-tab:not(.active) .rv-tab-n {
            background: var(--bg);
            color: var(--text-muted);
        }

        .rv-view-toggle {
            display: flex;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            overflow: hidden;
            flex-shrink: 0;
        }

        .rv-vbtn {
            width: 34px;
            height: 34px;
            border: none;
            background: var(--surface);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: var(--text-muted);
            cursor: pointer;
            transition: all var(--dur);
        }

            .rv-vbtn.active {
                background: var(--primary-bg);
                color: var(--primary);
            }

        /* Table */
        .rv-table-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .rv-table-head {
            padding: 14px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .rv-table-title {
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
        }

        .rv-table-sub {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .rv-tbl {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

            .rv-tbl th {
                padding: 10px 16px;
                text-align: left;
                font-size: 10.5px;
                font-weight: 700;
                letter-spacing: .07em;
                text-transform: uppercase;
                color: var(--text-muted);
                background: var(--bg);
                border-bottom: 1px solid var(--border);
                white-space: nowrap;
            }

            .rv-tbl td {
                padding: 13px 16px;
                border-bottom: 1px solid var(--border);
                vertical-align: middle;
            }

            .rv-tbl tbody tr:last-child td {
                border-bottom: none;
            }

            .rv-tbl tbody tr {
                transition: background var(--dur);
                cursor: pointer;
            }

                .rv-tbl tbody tr:hover {
                    background: #F8FAFF;
                }

        .rv-patient-cell {
            display: flex;
            align-items: center;
            gap: 9px;
        }

        .rv-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 700;
            color: #fff;
        }

        .rv-patient-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }

        .rv-patient-id {
            font-size: 10.5px;
            color: var(--text-muted);
        }

        .rv-doc-cell {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 13px;
        }

        .rv-doc-av {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 8px;
            font-weight: 700;
            color: #fff;
        }

        .rv-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 9px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            white-space: nowrap;
        }

            .rv-badge i {
                font-size: 6px;
            }

            .rv-badge.confirmed {
                background: var(--success-bg);
                color: #065F46;
            }

            .rv-badge.pending {
                background: var(--warning-bg);
                color: #92400E;
            }

            .rv-badge.cancelled {
                background: var(--danger-bg);
                color: #991B1B;
            }

            .rv-badge.completed {
                background: #F1F5F9;
                color: #475569;
            }

        .rv-priority {
            font-size: 10px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 4px;
        }

            .rv-priority.high {
                background: var(--danger-bg);
                color: #991B1B;
            }

            .rv-priority.normal {
                background: var(--primary-bg);
                color: var(--primary-dk);
            }

            .rv-priority.low {
                background: var(--success-bg);
                color: #065F46;
            }

        .rv-action-btn {
            width: 28px;
            height: 28px;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: transparent;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: var(--text-muted);
            cursor: pointer;
            transition: all var(--dur);
            margin-right: 3px;
        }

            .rv-action-btn:hover {
                background: var(--primary-bg);
                color: var(--primary);
                border-color: #C7D9F8;
            }

            .rv-action-btn.success:hover {
                background: var(--success-bg);
                color: var(--success);
                border-color: #A7F3D0;
            }

            .rv-action-btn.danger:hover {
                background: var(--danger-bg);
                color: var(--danger);
                border-color: #FCA5A5;
            }

        /* Card view */
        #rv-card-view {
            display: none;
            grid-template-columns: repeat(auto-fill,minmax(280px,1fr));
            gap: 16px;
        }

            #rv-card-view.active {
                display: grid;
            }

        .rv-appt-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease), border-color var(--dur);
            cursor: pointer;
            animation: rvUp .28s var(--ease) both;
        }

            .rv-appt-card:hover {
                box-shadow: 0 4px 20px rgba(59,130,246,.13);
                transform: translateY(-2px);
                border-color: #C7D9F8;
            }
        @@keyframes rvUp {
            from

        {
            opacity: 0;
            transform: translateY(12px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }

        }

        .rv-card-accent {
            height: 4px;
        }

        .rv-card-body {
            padding: 16px 18px;
            flex: 1;
        }

        .rv-card-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .rv-card-id {
            font-size: 10px;
            font-weight: 700;
            color: var(--text-muted);
            font-family: monospace;
        }

        .rv-card-date {
            font-size: 11px;
            font-weight: 700;
            color: var(--primary);
            background: var(--primary-bg);
            padding: 3px 9px;
            border-radius: 20px;
        }

        .rv-card-patient {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 2px;
        }

        .rv-card-meta {
            font-size: 11px;
            color: var(--text-muted);
            margin-bottom: 10px;
        }

        .rv-card-divider {
            height: 1px;
            background: var(--border);
            margin: 10px 0;
        }

        .rv-card-row {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 12px;
            color: var(--text-muted);
            margin-bottom: 6px;
        }

            .rv-card-row:last-child {
                margin-bottom: 0;
            }

            .rv-card-row i {
                font-size: 13px;
                color: var(--primary);
                flex-shrink: 0;
                width: 16px;
            }

        .rv-card-footer {
            padding: 10px 14px;
            border-top: 1px solid var(--border);
            background: #FAFBFE;
            display: flex;
            gap: 5px;
        }

        .rv-cbtn {
            flex: 1;
            border: 1px solid var(--border);
            background: var(--surface);
            border-radius: var(--radius-sm);
            padding: 6px 8px;
            font-size: 11px;
            font-weight: 600;
            font-family: inherit;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
            cursor: pointer;
            color: var(--text-muted);
            transition: all var(--dur);
        }

            .rv-cbtn.primary {
                color: var(--primary);
                border-color: #C7D9F8;
                background: var(--primary-bg);
            }

                .rv-cbtn.primary:hover {
                    background: var(--primary);
                    color: #fff;
                }

            .rv-cbtn.success {
                color: var(--success);
                border-color: #A7F3D0;
                background: var(--success-bg);
            }

                .rv-cbtn.success:hover {
                    background: var(--success);
                    color: #fff;
                }

            .rv-cbtn.danger:hover {
                background: var(--danger-bg);
                border-color: #FCA5A5;
                color: var(--danger);
            }

            .rv-cbtn:hover {
                background: var(--bg);
                color: var(--text);
            }

        /* Pagination */
        .rv-pagination {
            padding: 13px 20px;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .rv-page-info {
            font-size: 12px;
            color: var(--text-muted);
        }

        .rv-pages {
            display: flex;
            gap: 4px;
        }

        .rv-page-btn {
            width: 30px;
            height: 30px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            background: transparent;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            cursor: pointer;
            transition: all var(--dur);
        }

            .rv-page-btn:hover {
                background: var(--primary-bg);
                color: var(--primary);
                border-color: #C7D9F8;
            }

            .rv-page-btn.active {
                background: var(--primary);
                color: #fff;
                border-color: var(--primary);
            }

        /* Empty */
        .rv-empty {
            padding: 56px 24px;
            text-align: center;
            color: var(--text-muted);
        }

            .rv-empty i {
                font-size: 46px;
                opacity: .15;
                display: block;
                margin-bottom: 12px;
            }

        .rv-empty-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 5px;
        }

        /* Modal */
        .rv-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,.45);
            z-index: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
            opacity: 0;
            pointer-events: none;
            transition: opacity .2s ease;
        }

            .rv-overlay.show {
                opacity: 1;
                pointer-events: all;
            }

        .rv-modal-box {
            background: var(--surface);
            border-radius: var(--radius);
            box-shadow: 0 20px 60px rgba(0,0,0,.18);
            width: 100%;
            max-width: 520px;
            transform: scale(.93) translateY(16px);
            transition: transform .26s cubic-bezier(.34,1.56,.64,1);
            max-height: 90vh;
            display: flex;
            flex-direction: column;
        }

        .rv-overlay.show .rv-modal-box {
            transform: scale(1) translateY(0);
        }

        .rv-modal-header {
            padding: 18px 22px 14px;
            border-bottom: 1px solid var(--border);
            display: flex;
