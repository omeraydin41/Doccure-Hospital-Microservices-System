            A03:{id:'#R-1044',patient:'Fatma Yıldız',patid:'#H-0198',doctor:'Dr. Can Öztürk',branch:'Ortopedi',date:'27 Nisan 2026',time:'11:00 – 11:30',priority:'Düşük',status:'confirmed',note:'Diz artroskopi öncesi son muayene.'},
            A04:{id:'#R-1045',patient:'Emre Şahin',patid:'#H-0401',doctor:'Dr. Zeynep Kara',branch:'Nöroloji',date:'27 Nisan 2026',time:'14:00 – 14:30',priority:'Acil',status:'confirmed',note:'Migren atakları şiddetlendi. Profilaktik tedavi değerlendirme.'},
            A05:{id:'#R-1046',patient:'Merve Doğan',patid:'#H-0522',doctor:'Dr. Ahmet Yılmaz',branch:'Pediatri',date:'27 Nisan 2026',time:'15:30 – 16:00',priority:'Normal',status:'confirmed',note:'Rutin aşı takvimi kontrolü.'},
            A06:{id:'#R-1047',patient:'Kemal Arslan',patid:'#H-0611',doctor:'Dr. Neslihan Baş',branch:'Radyoloji',date:'28 Nisan 2026',time:'09:00 – 09:30',priority:'Normal',status:'pending',note:'Toraks BT çekimi planlandı.'},
            A07:{id:'#R-1050',patient:'Nilüfer Çetin',patid:'#H-0934',doctor:'Dr. Selin Arslan',branch:'Dermatoloji',date:'29 Nisan 2026',time:'10:00 – 10:30',priority:'Normal',status:'confirmed',note:'Psöriazis takip randevusu.'},
            A08:{id:'#R-1052',patient:'Sevgi Koç',patid:'#H-0734',doctor:'Dr. Mehmet Demir',branch:'Kardiyoloji',date:'30 Nisan 2026',time:'11:00 – 11:30',priority:'Acil',status:'confirmed',note:'Akut koroner şüphesi — acil kardiyoloji değerlendirme.'},
            A09:{id:'#R-1049',patient:'Bülent Yıldız',patid:'#H-0812',doctor:'Dr. Can Öztürk',branch:'Ortopedi',date:'28 Nisan 2026',time:'13:00 – 13:30',priority:'Düşük',status:'cancelled',note:'Hasta kendi isteğiyle iptal etti.'},
            A10:{id:'#R-1051',patient:'Tarık Demir',patid:'#H-1021',doctor:'Dr. Zeynep Kara',branch:'Nöroloji',date:'30 Nisan 2026',time:'09:30 – 10:00',priority:'Normal',status:'cancelled',note:'Doktor program değişikliği nedeniyle iptal edildi.'},
          };

          const SL = {confirmed:'Onaylandı',pending:'Beklemede',cancelled:'İptal',completed:'Tamamlandı'};
          const SC = {confirmed:'confirmed',pending:'pending',cancelled:'cancelled',completed:'completed'};
          const ACCENTS = {confirmed:'linear-gradient(90deg,var(--success),#34D399)',pending:'linear-gradient(90deg,var(--warning),#FCD34D)',cancelled:'linear-gradient(90deg,#94A3B8,#CBD5E1)',completed:'linear-gradient(90deg,var(--primary),#60A5FA)'};

          let _filter='all', _cancelName='', _cancelRow=null;
          let _calYear=2026, _calMonth=3, _selDay=27;

          /* Calendar */
          const MONTHS=['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
          const COK=[3,7,10,12,14,17,20,21,24,27,29];
          const CPEND=[5,13,19,28];
          const CBUSY=[7,14,21];

          function renderCal(){
            document.getElementById('rv-cal-label').textContent=MONTHS[_calMonth]+' '+_calYear;
            const c=document.getElementById('rv-cal-days'); c.innerHTML='';
            const first=new Date(_calYear,_calMonth,1).getDay();
            const off=first===0?6:first-1;
            const days=new Date(_calYear,_calMonth+1,0).getDate();
            const today=new Date();
            for(let i=0;i<off;i++){const d=document.createElement('div');d.className='rv-day other';d.textContent=new Date(_calYear,_calMonth,0).getDate()-off+1+i;c.appendChild(d);}
            for(let day=1;day<=days;day++){
              const d=document.createElement('div');
              let cls='rv-day';
              if(_calYear===today.getFullYear()&&_calMonth===today.getMonth()&&day===today.getDate()) cls+=' today';
              if(day===_selDay) cls+=' selected';
              if(CBUSY.includes(day))       cls+=' has-dot c-busy';
              else if(CPEND.includes(day))  cls+=' has-dot c-pend';
              else if(COK.includes(day))    cls+=' has-dot c-ok';
              d.className=cls; d.textContent=day;
              d.onclick=()=>{_selDay=day;renderCal();Shell.toast(`${day} ${MONTHS[_calMonth]} randevuları gösteriliyor.`,'info','bi-calendar3');};
              c.appendChild(d);
            }
            for(let i=1;i<=42-off-days;i++){const d=document.createElement('div');d.className='rv-day other';d.textContent=i;c.appendChild(d);}
          }
          function calPrev(){if(_calMonth===0){_calMonth=11;_calYear--;}else _calMonth--;renderCal();}
          function calNext(){if(_calMonth===11){_calMonth=0;_calYear++;}else _calMonth++;renderCal();}

          /* View */
          function setView(v){
            const tbl=document.getElementById('rv-table-view');
            const crd=document.getElementById('rv-card-view');
            document.getElementById('rv-vtbl').classList.toggle('active',v==='table');
            document.getElementById('rv-vcrd').classList.toggle('active',v==='card');
            if(v==='table'){tbl.style.display='';crd.style.display='none';}
            else{tbl.style.display='none';crd.style.display='grid';renderCards();}
          }

          function renderCards(){
            const crd=document.getElementById('rv-card-view');
            const q=(document.getElementById('rv-search').value||'').toLowerCase().trim();
            const items=Object.entries(DATA).filter(([,d])=>(_filter==='all'||d.status===_filter)&&(d.patient+' '+d.doctor+' '+d.branch).toLowerCase().includes(q));
            if(!items.length){
              crd.innerHTML=`<div class="rv-empty" style="grid-column:1/-1"><i class="bi bi-calendar-x"></i><div class="rv-empty-title">Randevu bulunamadı</div></div>`;
              return;
            }
            crd.innerHTML=items.map(([id,d],i)=>`
              <div class="rv-appt-card" style="animation-delay:${i*.05}s" onclick="RV.openDetail('${id}')">
                <div class="rv-card-accent" style="background:${ACCENTS[d.status]||ACCENTS.completed}"></div>
                <div class="rv-card-body">
                  <div class="rv-card-top">
                    <div class="rv-card-id">${d.id}</div>
                    <div class="rv-card-date">${d.date.split(' ').slice(0,2).join(' ')}</div>
                  </div>
                  <div class="rv-card-patient">${d.patient}</div>
                  <div class="rv-card-meta">${d.patid} · ${d.time}</div>
                  <div class="rv-card-divider"></div>
                  <div class="rv-card-row"><i class="bi bi-person-badge"></i>${d.doctor}</div>
                  <div class="rv-card-row"><i class="bi bi-diagram-3"></i>${d.branch}</div>
                  <div class="rv-card-row"><i class="bi bi-flag"></i>
                    <span class="rv-priority ${d.priority==='Acil'?'high':d.priority==='Düşük'?'low':'normal'}">${d.priority}</span>
                    <span class="rv-badge ${SC[d.status]||''}" style="margin-left:auto;font-size:10px"><i class="bi bi-circle-fill" style="font-size:5px"></i>${SL[d.status]||''}</span>
                  </div>
                </div>
                <div class="rv-card-footer" onclick="event.stopPropagation()">
                  <button class="rv-cbtn primary" onclick="RV.openDetail('${id}')"><i class="bi bi-eye"></i> Detay</button>
                  <button class="rv-cbtn success" onclick="RV.approve('${d.patient}',null)"><i class="bi bi-check-lg"></i> Onayla</button>
                  <button class="rv-cbtn danger"  onclick="RV.confirmCancel('${d.patient}',null)"><i class="bi bi-x-lg"></i></button>
                </div>
              </div>`).join('');
          }

          /* Tab / Filter */
          function setTab(el){
            document.querySelectorAll('.rv-tab').forEach(t=>t.classList.remove('active'));
            el.classList.add('active'); _filter=el.dataset.s; filter();
          }
          function filter(){
            const q=(document.getElementById('rv-search').value||'').toLowerCase().trim();
            let n=0;
            document.querySelectorAll('.rv-row').forEach(row=>{
              const show=(_filter==='all'||row.dataset.s===_filter)&&row.dataset.q.includes(q);
              row.style.display=show?'':'none'; if(show)n++;
            });
            const sub=document.getElementById('rv-sub');
            if(sub) sub.textContent=n+' randevu listeleniyor';
            let empty=document.getElementById('rv-tbl-empty');
            const tbody=document.getElementById('rv-tbody');
            if(n===0&&!empty){empty=document.createElement('tr');empty.id='rv-tbl-empty';empty.innerHTML=`<td colspan="8"><div class="rv-empty"><i class="bi bi-calendar-x"></i><div class="rv-empty-title">Randevu bulunamadı</div></div></td>`;tbody.appendChild(empty);}
            else if(n>0&&empty) empty.remove();
            if(document.getElementById('rv-card-view').style.display==='grid') renderCards();
          }
          function filterBranch(v){Shell.toast(v?`${v} branşı filtrelendi.`:'Tüm branşlar.','info','bi-funnel');}
          function sortBy(v){Shell.toast(`${v==='date'?'Tarihe':v==='patient'?'Hastaya':v==='doctor'?'Doktora':'Önceliğe'} göre sıralandı.`,'info','bi-sort-down');}
          function changePage(n){Shell.toast(`Sayfa ${n} yükleniyor...`,'info','bi-arrow-right');}

          /* Modal */
          function open(id){document.getElementById(id).classList.add('show');document.body.style.overflow='hidden';}
          function close(id){document.getElementById(id).classList.remove('show');document.body.style.overflow='';}

          /* Detail */
          function openDetail(id){
            const d=DATA[id]; if(!d) return;
            document.getElementById('rv-d-id').textContent=d.id;
            document.getElementById('rv-d-patient').textContent=d.patient;
            document.getElementById('rv-d-patid').textContent=d.patid;
            document.getElementById('rv-d-doctor').textContent=d.doctor;
            document.getElementById('rv-d-branch').textContent=d.branch;
            document.getElementById('rv-d-date').textContent=d.date;
            document.getElementById('rv-d-time').textContent=d.time;
            document.getElementById('rv-d-priority').textContent=d.priority;
            document.getElementById('rv-d-note').textContent=d.note;
            document.getElementById('rv-d-sbadge').innerHTML=`<span class="rv-badge ${SC[d.status]||''}"><i class="bi bi-circle-fill" style="font-size:7px"></i>${SL[d.status]||''}</span>`;
            open('rv-m-detail');
          }

          /* New/Edit */
          function openNew(){
            document.getElementById('rv-e-title').innerHTML='<i class="bi bi-calendar-plus me-2" style="color:var(--primary)"></i>Yeni Randevu';
            document.getElementById('rv-e-sub').textContent='Randevu bilgilerini doldurun';
            document.getElementById('rv-e-patient').value='';
            document.getElementById('rv-e-patid').value='';
            document.getElementById('rv-e-date').value='2026-04-27';
            open('rv-m-edit');
          }
          function openEdit(id){
            const d=DATA[id];
            if(d){document.getElementById('rv-e-title').innerHTML='<i class="bi bi-pencil me-2" style="color:var(--primary)"></i>Randevuyu Düzenle';document.getElementById('rv-e-sub').textContent=d.id+' · '+d.patient;document.getElementById('rv-e-patient').value=d.patient;document.getElementById('rv-e-patid').value=d.patid;}
            open('rv-m-edit');
          }
          function saveEdit(){
            const p=document.getElementById('rv-e-patient').value.trim();
            if(!p){Shell.toast('Hasta adı boş olamaz!','danger','bi-exclamation-circle');return;}
            close('rv-m-edit'); Shell.toast(`${p} randevusu kaydedildi.`,'success','bi-calendar-check');
          }

          /* Approve / Complete */
          function approve(name,btn){
            if(btn){const row=btn.closest('.rv-row');const b=row?.querySelector('.rv-badge');if(b){b.className='rv-badge confirmed';b.innerHTML='<i class="bi bi-circle-fill" style="font-size:6px"></i>Onaylandı';}}
            Shell.toast(`${name} randevusu onaylandı.`,'success','bi-check-circle');
          }
          function complete(name){Shell.toast(`${name} randevusu tamamlandı olarak işaretlendi.`,'success','bi-clipboard-check');}

          /* Cancel */
          function confirmCancel(name,btn){_cancelName=name;_cancelRow=btn?.closest('.rv-row')||null;document.getElementById('rv-cancel-name').textContent=name;open('rv-m-cancel');}
          function execCancel(){
            close('rv-m-cancel');
            if(_cancelRow){_cancelRow.style.transition='opacity .3s ease';_cancelRow.style.opacity='0';setTimeout(()=>{_cancelRow?.remove();_cancelRow=null;filter();},320);}
            Shell.toast(`${_cancelName} randevusu iptal edildi.`,'danger','bi-calendar-x');
          }

          /* Export */
          function exportList(){Shell.toast('Randevu listesi Excel olarak hazırlanıyor...','info','bi-file-earmark-spreadsheet');}

          /* ESC */
          document.addEventListener('keydown',e=>{if(e.key==='Escape') document.querySelectorAll('.rv-overlay.show').forEach(m=>close(m.id));});

          /* Init */
          renderCal();
          document.getElementById('rv-today-lbl').textContent=new Date().toLocaleDateString('tr-TR',{day:'numeric',month:'long',year:'numeric'});
          if(typeof Shell!=='undefined'&&Shell.setPage) Shell.setPage('Randevular','Admin Paneli / İşlemler / Randevular');

          return {calPrev,calNext,setView,setTab,filter,filterBranch,sortBy,changePage,openDetail,openNew,openEdit,saveEdit,approve,complete,confirmCancel,execCancel,exportList,close};
        })();
    </script>

</main>
