    <script>
        const RV = (() => {

          const DATA = {
            A01:{id:'#R-1042',patient:'Ayşe Kaya',patid:'#H-0284',doctor:'Dr. Mehmet Demir',branch:'Kardiyoloji',date:'27 Nisan 2026',time:'09:00 – 09:30',priority:'Acil',status:'confirmed',note:'Efor testi sonrası rutin kontrol. Kan basıncı takibi yapılacak.'},
